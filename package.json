{
  "name": "webdata-pro",
  "version": "2.0.0",
  "description": "Metadata-driven web database application builder",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "ts-node node_modules/.bin/knex migrate:latest --knexfile knexfile.ts",
    "migrate:rollback": "ts-node node_modules/.bin/knex migrate:rollback --knexfile knexfile.ts",
    "migrate:make": "ts-node node_modules/.bin/knex migrate:make --knexfile knexfile.ts",
    "seed": "ts-node node_modules/.bin/knex seed:run --knexfile knexfile.ts",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^12.8.0",
    "connect-sqlite3": "^0.9.16",
    "cors": "^2.8.6",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "knex": "^3.0.1",
    "multer": "^2.1.1",
    "mysql2": "^3.22.0",
    "nodemailer": "^8.0.5",
    "nunjucks": "^3.2.4",
    "otplib": "^13.4.0",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/connect-sqlite3": "^0.9.6",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.17.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.11.5",
    "@types/nodemailer": "^8.0.0",
    "@types/nunjucks": "^3.2.6",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "playwright": "^1.59.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
