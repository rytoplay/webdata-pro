{
  "name": "webdata-pro",
  "version": "2.0.0",
  "description": "Metadata-driven web database application builder",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "ts-node node_modules/.bin/knex migrate:latest --knexfile knexfile.ts",
    "migrate:rollback": "ts-node node_modules/.bin/knex migrate:rollback --knexfile knexfile.ts",
    "migrate:make": "ts-node node_modules/.bin/knex migrate:make --knexfile knexfile.ts",
    "seed": "ts-node node_modules/.bin/knex seed:run --knexfile knexfile.ts"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "knex": "^3.0.1",
    "nunjucks": "^3.2.4",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.17.10",
    "@types/node": "^20.11.5",
    "@types/nunjucks": "^3.2.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
