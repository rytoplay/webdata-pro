<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}{{ title }} — Webdata Pro 2.0{% endblock %}</title>
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    :root {
      --sidebar-from: #2d356e;
      --sidebar-to:   #6643b5;
      --accent:       #5b6ef5;
      --accent-soft:  #eef0ff;
      --body-bg:      #f4f3fb;
      --border:       #e4e2f5;
      --text-main:    #2d2b55;
      --text-muted:   #9794b8;
      --radius-card:  16px;
      --radius-btn:   10px;
      --radius-input: 10px;
    }

    *, *::before, *::after { box-sizing: border-box; }

    body {
      font-family: 'Nunito', sans-serif;
      background: var(--body-bg);
      color: var(--text-main);
      margin: 0;
    }

    /* ── Sidebar ──────────────────────────────── */
    .sidebar {
      width: 230px;
      min-height: 100vh;
      background: linear-gradient(160deg, var(--sidebar-from), var(--sidebar-to));
      flex-shrink: 0;
      display: flex;
      flex-direction: column;
    }

    .sidebar .brand {
      padding: 1.25rem 1.25rem 0.75rem;
      color: #fff;
      font-weight: 800;
      font-size: 1rem;
      border-bottom: 1px solid rgba(255,255,255,0.12);
    }

    .sidebar .brand .tagline {
      font-size: 0.7rem;
      font-weight: 500;
      opacity: 0.6;
      margin-top: 0.15rem;
    }

    /* Current app context block */
    .sidebar .current-app-block {
      padding: 0.6rem 1rem 0.6rem;
      background: rgba(0,0,0,0.15);
      border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .sidebar .current-app-block .app-label {
      font-size: 0.68rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      color: rgba(255,255,255,0.5);
      margin-bottom: 0.2rem;
    }

    .sidebar .current-app-block .app-name {
      font-size: 0.875rem;
      font-weight: 800;
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .sidebar .current-app-block .app-name .dot {
      width: 7px;
      height: 7px;
      background: #6ee7b7;
      border-radius: 50%;
      flex-shrink: 0;
      margin-right: 0.4rem;
    }

    .btn-switch-app {
      background: none;
      border: 1px solid rgba(255,255,255,0.3);
      border-radius: 6px;
      color: rgba(255,255,255,0.7);
      font-family: 'Nunito', sans-serif;
      font-size: 0.7rem;
      font-weight: 700;
      padding: 0.1rem 0.45rem;
      cursor: pointer;
      white-space: nowrap;
      transition: background 0.15s, color 0.15s;
    }
    .btn-switch-app:hover {
      background: rgba(255,255,255,0.15);
      color: #fff;
    }

    .sidebar .nav-link {
      color: rgba(255,255,255,0.65);
      padding: 0.45rem 0.9rem;
      border-radius: 10px;
      margin: 1px 8px;
      font-weight: 600;
      font-size: 0.875rem;
      transition: background 0.15s, color 0.15s;
    }
    .sidebar .nav-link i { width: 1.3em; opacity: 0.85; }
    .sidebar .nav-link:hover {
      color: #fff;
      background: rgba(255,255,255,0.13);
    }
    .sidebar .nav-section-label {
      font-size: 0.65rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: rgba(255,255,255,0.35);
      padding: 0.75rem 1rem 0.25rem;
    }
    .sidebar .nav-link.dimmed {
      opacity: 0.4;
      pointer-events: none;
    }

    /* ── Main ─────────────────────────────────── */
    .main-content { flex: 1; min-width: 0; padding: 2rem 2.5rem; }

    .page-header {
      display: flex; align-items: center;
      justify-content: space-between; margin-bottom: 1.75rem;
    }
    .page-header h1 { font-size: 1.45rem; font-weight: 800; margin: 0; }

    /* ── Cards ────────────────────────────────── */
    .card {
      border: 1.5px solid var(--border);
      border-radius: var(--radius-card);
      box-shadow: 0 2px 14px rgba(91,110,245,0.06);
    }
    .card-footer {
      border-top: 1.5px solid var(--border);
      border-radius: 0 0 var(--radius-card) var(--radius-card);
    }

    /* ── Buttons ──────────────────────────────── */
    .btn { border-radius: var(--radius-btn); font-weight: 700; font-size: 0.875rem; }
    .btn-primary { background: var(--accent); border-color: var(--accent); }
    .btn-primary:hover { background: #4a5ce0; border-color: #4a5ce0; }

    /* ── Inputs ───────────────────────────────── */
    .form-control, .form-select {
      border-radius: var(--radius-input);
      border-color: var(--border);
      font-family: 'Nunito', sans-serif;
      font-size: 0.9rem; color: var(--text-main);
    }
    .form-control:focus, .form-select:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(91,110,245,0.13);
    }
    .form-label { font-weight: 700; font-size: 0.875rem; }
    .form-text  { font-size: 0.8rem; color: var(--text-muted); }

    /* ── Tables ───────────────────────────────── */
    .table { font-size: 0.9rem; }
    .table-light th {
      font-weight: 800; font-size: 0.75rem;
      text-transform: uppercase; letter-spacing: 0.05em;
      color: var(--text-muted); background: #f9f8ff;
    }

    /* ── Alerts ───────────────────────────────── */
    .alert { border-radius: 12px; font-weight: 600; border: none; }
    .alert-success { background: #f0fdf4; color: #166534; }
    .alert-danger  { background: #fef2f2; color: #991b1b; }
    .alert-warning { background: #fffbeb; color: #92400e; }
    .alert-info    { background: var(--accent-soft); color: #3730a3; }

    .badge { border-radius: 6px; font-weight: 700; }

    /* ── Logout ───────────────────────────────── */
    .btn-logout {
      width: 100%; background: rgba(255,255,255,0.1);
      border: 1.5px solid rgba(255,255,255,0.2);
      color: rgba(255,255,255,0.75); border-radius: 10px;
      font-weight: 700; font-size: 0.8rem; padding: 0.45rem 0.75rem;
      transition: background 0.15s, color 0.15s;
      font-family: 'Nunito', sans-serif; cursor: pointer;
    }
    .btn-logout:hover { background: rgba(255,255,255,0.2); color: #fff; }
  </style>
</head>
<body>
<div class="d-flex">

  <nav class="sidebar">
    <div class="brand">
      <div><i class="bi bi-database-fill-gear me-2"></i>Webdata Pro 2.0</div>
      <div class="tagline">Build databases. No stress.</div>
    </div>

    {% if currentApp %}
    <div class="current-app-block">
      <div class="app-label">Current app</div>
      <div class="app-name">
        <span><span class="dot"></span>{{ currentApp.name }}</span>
        <form method="POST" action="/admin/apps/deselect" class="d-inline">
          <button class="btn-switch-app">Switch</button>
        </form>
      </div>
    </div>
    {% endif %}

    <ul class="nav flex-column px-1 mt-2 flex-grow-1">
      <div class="nav-section-label">{{ currentApp.name if currentApp else 'App' }}</div>
      <li class="nav-item">
        <a class="nav-link {% if not currentApp %}dimmed{% endif %}" href="/admin/blueprint">
          <i class="bi bi-stars"></i> AI Builder
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link {% if not currentApp %}dimmed{% endif %}" href="/admin/tables">
          <i class="bi bi-table"></i> Tables
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link {% if not currentApp %}dimmed{% endif %}" href="/admin/data">
          <i class="bi bi-grid-3x3-gap"></i> Data
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link {% if not currentApp %}dimmed{% endif %}" href="/admin/joins">
          <i class="bi bi-diagram-2"></i> Joins
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link {% if not currentApp %}dimmed{% endif %}" href="/admin/views">
          <i class="bi bi-eye"></i> Views
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link {% if not currentApp %}dimmed{% endif %}" href="/admin/groups">
          <i class="bi bi-people"></i> Groups
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link {% if not currentApp %}dimmed{% endif %}" href="/admin/members">
          <i class="bi bi-person"></i> Members
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link {% if not currentApp %}dimmed{% endif %}" href="/admin/app-settings">
          <i class="bi bi-sliders"></i> App Settings
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link {% if not currentApp %}dimmed{% endif %}" href="/admin/auth">
          <i class="bi bi-shield-lock"></i> Auth / SSO
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link {% if not currentApp %}dimmed{% endif %}" href="/admin/sql">
          <i class="bi bi-terminal"></i> SQL Console
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link {% if not currentApp %}dimmed{% endif %}" href="/admin/endpoints">
          <i class="bi bi-signpost-split"></i> Endpoints
        </a>
      </li>
    </ul>

    <div class="px-3 pb-4">
      <a class="nav-link mb-2" href="/admin/settings" style="font-size:0.82rem;">
        <i class="bi bi-gear me-1"></i> Settings
      </a>
      <form method="POST" action="/admin/logout">
        <button class="btn-logout"><i class="bi bi-box-arrow-right me-1"></i> Log out</button>
      </form>
    </div>
  </nav>

  <main class="main-content">
    {% if flash %}
    <div class="alert alert-{{ flash.type }} alert-dismissible fade show mb-4" role="alert">
      {{ flash.message }}
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    {% endif %}
    {% block content %}{% endblock %}
  </main>

</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
