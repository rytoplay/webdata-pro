{% extends "admin/layout.njk" %}
{% block content %}
<div class="page-header">
  <h1><i class="bi bi-sliders me-2"></i>App Settings</h1>
</div>

<div class="row g-4">

  <!-- ── CORS / Allowed Origins ───────────────────────────────────────────── -->
  <div class="col-12 col-lg-7">
    <div class="card">
      <div class="card-header fw-bold py-3 px-4">
        <i class="bi bi-globe me-2 text-primary"></i>Allowed Origins (CORS)
      </div>
      <div class="card-body p-4">
        {% if flash %}
        <div class="alert alert-{{ flash.type }} alert-dismissible fade show mb-4" role="alert">
          {{ flash.message }}
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        {% endif %}

        <p class="text-muted small mb-3">
          List the websites allowed to embed this app's widget. Enter one origin per line
          (scheme + hostname + optional port). Use <code>*</code> on its own line to allow
          any origin (useful during development).
        </p>

        <form method="POST" action="/admin/app-settings">
          <div class="mb-3">
            <label class="form-label" for="allowed_origins">Allowed origins</label>
            <textarea
              id="allowed_origins"
              name="allowed_origins"
              class="form-control font-monospace"
              rows="8"
              placeholder="https://localshelter.com&#10;https://www.mypetstore.com&#10;http://localhost:8080"
              spellcheck="false"
            >{{ originsText }}</textarea>
            <div class="form-text">
              One origin per line — e.g. <code>https://localshelter.com</code>.
              Do <strong>not</strong> include a trailing slash or path.
            </div>
          </div>
          <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-lg me-1"></i>Save
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- ── Member Branding ─────────────────────────────────────────────────── -->
  <div class="col-12">
    <div class="card">
      <div class="card-header fw-bold py-3 px-4">
        <i class="bi bi-palette me-2 text-primary"></i>Member Portal Branding
      </div>
      <div class="card-body p-4">
        <p class="text-muted small mb-4">
          Give your member login, home, and view pages a custom look. Enter a CSS URL and
          paste header/footer HTML that matches your public website. Templates support
          <a href="https://mozilla.github.io/nunjucks/templating.html" target="_blank">Nunjucks</a>
          — use <code>{{ "{{" }} app.name {{ "}}" }}</code>, <code>{{ "{{" }} member.first_name {{ "}}" }}</code>,
          and <code>{{ "{{" }} logoutUrl {{ "}}" }}</code> anywhere in the HTML.
        </p>
        <form method="POST" action="/admin/app-settings">
          <input type="hidden" name="allowed_origins" value="{{ originsText }}">

          <div class="mb-3">
            <label class="form-label" for="member_css_url">Custom CSS URL</label>
            <input type="text" id="member_css_url" name="member_css_url"
              class="form-control font-monospace"
              placeholder="/static/css/pet-shelter.css"
              value="{{ memberCssUrl }}">
            <div class="form-text">
              Path or full URL to your stylesheet. Leave blank to use the default Bootstrap style.
              Example: <code>/static/css/pet-shelter.css</code>
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label" for="member_header_html">Header HTML</label>
            <textarea id="member_header_html" name="member_header_html"
              class="form-control font-monospace" rows="10"
              placeholder="<header>...</header>&#10;<nav>...</nav>"
              spellcheck="false">{{ memberHeaderHtml }}</textarea>
            <div class="form-text">
              Rendered above the page content on login, home, and view pages.
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label" for="member_footer_html">Footer HTML</label>
            <textarea id="member_footer_html" name="member_footer_html"
              class="form-control font-monospace" rows="6"
              placeholder="<footer>...</footer>"
              spellcheck="false">{{ memberFooterHtml }}</textarea>
            <div class="form-text">
              Rendered below the page content.
            </div>
          </div>

          <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-lg me-1"></i>Save Branding
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- ── Database Connection (non-SQLite only) ──────────────────────────── -->
  {% if dbMode !== 'sqlite' %}
  <div class="col-12">
    <div class="card">
      <div class="card-header fw-bold py-3 px-4">
        <i class="bi bi-database me-2 text-primary"></i>Database Connection
      </div>
      <div class="card-body p-4">
        <p class="text-muted small mb-4">
          Update the connection credentials for this app's {{ dbMode }} database.
          The connection pool will be reset immediately on save.
        </p>
        <form method="POST" action="/admin/apps/{{ app.id }}/db-config">
          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <label class="form-label">Host</label>
              <input type="text" name="db_host" class="form-control font-monospace"
                value="{{ dbCfg.host or 'localhost' }}" placeholder="localhost">
            </div>
            <div class="col-md-2">
              <label class="form-label">Port</label>
              <input type="number" name="db_port" class="form-control font-monospace"
                value="{{ dbCfg.port or (3306 if dbMode == 'mysql' else 5432) }}">
            </div>
            <div class="col-md-4">
              <label class="form-label">Database Name</label>
              <input type="text" name="db_name" class="form-control font-monospace"
                value="{{ dbCfg.database or '' }}">
            </div>
          </div>
          <div class="row g-3 mb-4">
            <div class="col-md-6">
              <label class="form-label">Username</label>
              <input type="text" name="db_username" class="form-control font-monospace"
                autocomplete="off" value="{{ dbCfg.username or '' }}">
            </div>
            <div class="col-md-6">
              <label class="form-label">Password</label>
              <input type="password" name="db_password" class="form-control"
                autocomplete="new-password" placeholder="(leave blank to keep existing)">
            </div>
          </div>
          <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-lg me-1"></i>Save Connection
          </button>
        </form>
      </div>
    </div>
  </div>
  {% endif %}

  <!-- ── Help panel ───────────────────────────────────────────────────────── -->
  <div class="col-12 col-lg-5">
    <div class="card h-100">
      <div class="card-header fw-bold py-3 px-4">
        <i class="bi bi-info-circle me-2 text-primary"></i>What is an origin?
      </div>
      <div class="card-body p-4 small text-muted">
        <p>
          An <strong>origin</strong> is the combination of <em>scheme</em>, <em>hostname</em>,
          and <em>port</em> — no path. Examples:
        </p>
        <ul class="mb-3">
          <li><code>https://localshelter.com</code></li>
          <li><code>http://localhost:3000</code></li>
          <li><code>https://www.mypetstore.com</code></li>
        </ul>
        <p>
          When a visitor's browser loads the widget on one of these sites, it sends an
          <code>Origin</code> header with that value. Webdata Pro checks the list and
          returns the correct <code>Access-Control-Allow-Origin</code> header so the
          embed script can fetch data.
        </p>
        <p>
          If the list is <strong>empty</strong>, no cross-origin requests are allowed
          (only same-origin — i.e. pages served directly by this server).
        </p>
        <p class="mb-0">
          Add <code>*</code> to allow <em>any</em> origin. Fine for public read-only
          widgets; avoid for apps with member authentication.
        </p>
      </div>
    </div>
  </div>

</div>
{% endblock %}
