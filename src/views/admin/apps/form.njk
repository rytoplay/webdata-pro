{% extends "admin/layout.njk" %}

{% block content %}
<div class="page-header">
  <h1>New App</h1>
  <a href="/admin" class="btn btn-sm btn-outline-secondary">&larr; Back</a>
</div>

<div class="card shadow-sm" style="max-width:600px">
  <div class="card-body p-4">
    <p class="text-muted mb-4" style="font-size:0.9rem;">
      Each app is its own database context — its own set of tables, members, groups, and views.
      Think of it like a schema in a database client.
    </p>

    <form method="POST" action="/admin/apps">

      {# ── Identity ──────────────────────────────────────────────── #}
      <div class="mb-3">
        <label class="form-label">App name <span class="text-danger">*</span></label>
        <input type="text" name="name" class="form-control {% if errors.name %}is-invalid{% endif %}"
          value="{{ values.name if values else '' }}"
          placeholder="e.g. Customer Portal" autofocus required>
        {% if errors.name %}<div class="invalid-feedback">{{ errors.name[0] }}</div>{% endif %}
      </div>

      <div class="mb-4">
        <label class="form-label">Description <span class="text-muted fw-normal">(100 chars max)</span></label>
        <textarea name="description" class="form-control {% if errors.description %}is-invalid{% endif %}"
          rows="2" maxlength="100"
          placeholder="What is this app for? e.g. Manages customer orders and inventory for the online store."
          oninput="document.getElementById('desc-count').textContent=this.value.length">{{ values.description if values else '' }}</textarea>
        {% if errors.description %}
        <div class="invalid-feedback">{{ errors.description[0] }}</div>
        {% else %}
        <div class="form-text"><span id="desc-count">{{ (values.description if values else '')|length }}</span> / 100</div>
        {% endif %}
      </div>

      {# ── Database type ─────────────────────────────────────────── #}
      <div class="mb-3">
        <label class="form-label">Database type <span class="text-danger">*</span></label>
        <div class="d-flex gap-3 flex-wrap">

          {% set modes = [
            { value: 'sqlite',   label: 'SQLite',     icon: 'bi-file-earmark-binary', hint: 'Local file — zero setup, great for getting started' },
            { value: 'mysql',    label: 'MySQL',       icon: 'bi-server',              hint: 'Connect to a MySQL or MariaDB server' },
            { value: 'postgres', label: 'PostgreSQL',  icon: 'bi-server',              hint: 'Connect to a PostgreSQL server' }
          ] %}

          {% for mode in modes %}
          {% set isSelected = values and values.database_mode == mode.value %}
          <label class="db-type-card {% if isSelected %}selected{% endif %}" for="mode-{{ mode.value }}">
            <input type="radio" name="database_mode" id="mode-{{ mode.value }}" value="{{ mode.value }}"
              {% if isSelected or (not values and mode.value == 'sqlite') %}checked{% endif %}
              onchange="showDbFields(this.value)">
            <i class="bi {{ mode.icon }} db-icon"></i>
            <span class="db-label">{{ mode.label }}</span>
            <span class="db-hint">{{ mode.hint }}</span>
          </label>
          {% endfor %}

        </div>
      </div>

      {# ── SQLite config ─────────────────────────────────────────── #}
      <div id="config-sqlite" class="db-config-section mb-4">
        <label class="form-label">SQLite file path</label>
        <input type="text" name="sqlite_path" class="form-control"
          value="{{ values.sqlite_path if values else '' }}"
          placeholder="./my-app.sqlite">
        <div class="form-text">
          Relative to the project root, or use an absolute path.
          Leave blank to use <code>./data.sqlite</code>.
        </div>
      </div>

      {# ── MySQL / PostgreSQL config ──────────────────────────────── #}
      <div id="config-remote" class="db-config-section mb-4" style="display:none">
        <div class="row g-3 mb-3">
          <div class="col-md-8">
            <label class="form-label">Host</label>
            <input type="text" name="db_host" class="form-control"
              value="{{ values.db_host if values else '' }}" placeholder="localhost">
          </div>
          <div class="col-md-4">
            <label class="form-label">Port</label>
            <input type="number" name="db_port" class="form-control" id="db-port-input"
              value="{{ values.db_port if values else '' }}" placeholder="3306">
          </div>
        </div>
        <div class="row g-3 mb-3">
          <div class="col-md-12">
            <label class="form-label">Database name</label>
            <input type="text" name="db_name" class="form-control"
              value="{{ values.db_name if values else '' }}" placeholder="my_database">
          </div>
        </div>
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label">Username</label>
            <input type="text" name="db_username" class="form-control" autocomplete="off"
              value="{{ values.db_username if values else '' }}" placeholder="root">
          </div>
          <div class="col-md-6">
            <label class="form-label">Password</label>
            <input type="password" name="db_password" class="form-control" autocomplete="new-password"
              value="{{ values.db_password if values else '' }}">
            <div class="form-text">Stored locally in the control database.</div>
          </div>
        </div>
      </div>

      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Create App</button>
        <a href="/admin" class="btn btn-outline-secondary">Cancel</a>
      </div>

    </form>
  </div>
</div>

<style>
  .db-type-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.15rem;
    padding: 0.75rem 1rem;
    border: 1.5px solid var(--border);
    border-radius: 12px;
    cursor: pointer;
    min-width: 150px;
    flex: 1;
    transition: border-color 0.15s, box-shadow 0.15s;
    background: #fff;
  }
  .db-type-card input[type="radio"] { display: none; }
  .db-type-card .db-icon { font-size: 1.25rem; color: var(--text-muted); margin-bottom: 0.1rem; }
  .db-type-card .db-label { font-weight: 800; font-size: 0.875rem; color: var(--text-main); }
  .db-type-card .db-hint  { font-size: 0.72rem; color: var(--text-muted); line-height: 1.3; }
  .db-type-card:hover { border-color: #a5b4fc; }
  .db-type-card.selected,
  .db-type-card:has(input:checked) {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(91,110,245,0.13);
  }
  .db-type-card:has(input:checked) .db-icon { color: var(--accent); }
</style>

<script>
  const defaultPorts = { mysql: 3306, postgres: 5432 };

  function showDbFields(mode) {
    document.getElementById('config-sqlite').style.display = mode === 'sqlite' ? '' : 'none';
    document.getElementById('config-remote').style.display = mode !== 'sqlite' ? '' : 'none';
    const portInput = document.getElementById('db-port-input');
    if (defaultPorts[mode]) portInput.placeholder = defaultPorts[mode];
    document.querySelectorAll('.db-type-card').forEach(card => {
      card.classList.toggle('selected', card.querySelector('input').value === mode);
    });
  }

  // Auto-fill SQLite path from app name, unless the user has manually edited the path field
  const nameInput     = document.querySelector('input[name="name"]');
  const sqliteInput   = document.querySelector('input[name="sqlite_path"]');
  let pathUserEdited  = sqliteInput.value !== '';  // if server re-rendered with a value, treat as edited

  function nameToPath(name) {
    return './' + name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '') + '.sqlite';
  }

  nameInput.addEventListener('input', () => {
    if (!pathUserEdited) {
      const slug = nameInput.value.trim();
      sqliteInput.value = slug ? nameToPath(slug) : '';
    }
  });

  sqliteInput.addEventListener('input', () => {
    // Once the user touches the path field themselves, stop auto-filling
    pathUserEdited = true;
  });

  // Clear the "edited" lock if the user clears the path field entirely,
  // so auto-fill resumes if they want a fresh suggestion
  sqliteInput.addEventListener('blur', () => {
    if (sqliteInput.value === '') pathUserEdited = false;
  });

  // Init on page load
  const checked = document.querySelector('input[name="database_mode"]:checked');
  if (checked) showDbFields(checked.value);
</script>
{% endblock %}
