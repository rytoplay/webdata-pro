{% extends "admin/layout.njk" %}

{% block content %}
<div class="page-header">
  <h1>Fields — <span class="text-muted fw-normal">{{ table.label }}</span></h1>
  <div class="d-flex gap-2">
    <a href="/admin/tables" class="btn btn-sm btn-outline-secondary">&larr; Tables</a>
    <a href="/admin/fields/new?table_id={{ table.id }}" class="btn btn-sm btn-primary">
      <i class="bi bi-plus-lg me-1"></i>Add Fields
    </a>
  </div>
</div>

{% if fields.length === 0 %}
<div class="text-center text-muted py-5">
  <i class="bi bi-list-columns fs-1 d-block mb-2"></i>
  No fields yet. <a href="/admin/fields/new?table_id={{ table.id }}">Add one</a>.
</div>
{% else %}
<p class="text-muted mb-2" style="font-size:0.8rem;">
  <i class="bi bi-grip-vertical me-1"></i>Drag rows to reorder. Order is saved automatically.
</p>
<div class="card shadow-sm">
  <table class="table table-hover mb-0" id="fields-table">
    <thead class="table-light">
      <tr>
        <th style="width:32px;"></th>
        <th style="width:36px;">#</th>
        <th>Name</th>
        <th>Label</th>
        <th>Type</th>
        <th>Widget</th>
        <th style="width:44px;" title="Required">Req</th>
        <th style="width:44px;" title="Primary Key">PK</th>
        <th style="width:44px;" title="Indexed">Idx</th>
        <th></th>
      </tr>
    </thead>
    <tbody id="fields-tbody">
      {% for field in fields %}
      <tr class="field-row" data-field-id="{{ field.id }}" draggable="true">
        <td class="drag-handle-cell">
          <span class="drag-handle" title="Drag to reorder">
            <i class="bi bi-grip-vertical"></i>
          </span>
        </td>
        <td class="sort-num text-muted small">{{ loop.index0 }}</td>
        <td><code>{{ field.field_name }}</code></td>
        <td>{{ field.label }}</td>
        <td><span class="badge bg-light text-dark border">{{ field.data_type }}</span></td>
        <td class="text-muted small">{{ field.ui_widget }}</td>
        <td>{% if field.is_required %}<i class="bi bi-check text-success"></i>{% endif %}</td>
        <td>{% if field.is_primary_key %}<i class="bi bi-key text-warning"></i>{% endif %}</td>
        <td>
          {% if field.is_indexed %}<i class="bi bi-lightning-charge text-primary" title="Indexed"></i>{% endif %}
          {% if field.is_fulltext_indexed %}<i class="bi bi-search text-success ms-1" title="Fulltext indexed"></i>{% endif %}
        </td>
        <td class="text-end">
          {% if not field.is_primary_key %}
          <button class="btn btn-sm btn-outline-secondary me-1"
            data-redefine
            data-id="{{ field.id }}"
            data-name="{{ field.field_name }}"
            data-label="{{ field.label }}"
            data-type="{{ field.data_type }}"
            data-widget="{{ field.ui_widget }}"
            data-options="{{ field.ui_options_json or '' }}"
            data-indexed="{{ 'true' if field.is_indexed else 'false' }}"
            data-fulltext="{{ 'true' if field.is_fulltext_indexed else 'false' }}">
            Redefine
          </button>
          <form method="POST" action="/admin/fields/{{ field.id }}/delete" class="d-inline"
            onsubmit="return confirm('Delete field &quot;{{ field.label }}&quot;? This will drop the column and update templates.')">
            <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
          </form>
          {% endif %}
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% endif %}

<style>
  .drag-handle-cell { width: 32px; padding: 0 4px !important; vertical-align: middle; }
  .drag-handle {
    display: inline-flex; align-items: center; justify-content: center;
    width: 24px; height: 28px;
    cursor: grab; color: var(--text-muted); border-radius: 4px;
    transition: color 0.1s, background 0.1s;
  }
  .drag-handle:hover { color: var(--accent); background: var(--accent-soft); }
  .drag-handle:active { cursor: grabbing; }
  tr.field-row { transition: opacity 0.15s; }
  tr.field-row.dragging { opacity: 0.35; }
  tr.field-row.drag-over-top    { box-shadow: inset 0 2px 0 var(--accent); }
  tr.field-row.drag-over-bottom { box-shadow: inset 0 -2px 0 var(--accent); }
  #save-indicator {
    position: fixed; bottom: 1.25rem; right: 1.5rem;
    background: #166534; color: #fff;
    padding: 0.4rem 1rem; border-radius: 8px;
    font-size: 0.8rem; font-weight: 700;
    opacity: 0; transition: opacity 0.3s;
    pointer-events: none;
  }
  #save-indicator.visible { opacity: 1; }
</style>

<div id="save-indicator"><i class="bi bi-check-circle me-1"></i>Order saved</div>

{# ── Redefine Field modal ─────────────────────────────────────────────────── #}
<div class="modal fade" id="redefineModal" tabindex="-1" aria-labelledby="redefineModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <form method="POST" id="redefineForm">
        <div class="modal-header">
          <h5 class="modal-title" id="redefineModalLabel">Redefine Field</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label fw-semibold">Field Name <small class="text-muted">(changing this updates all templates)</small></label>
            <input type="text" class="form-control font-monospace" name="field_name" id="rd-field-name" required pattern="[a-z][a-z0-9_]*">
            <div class="form-text">Lowercase letters, numbers, underscores. Must start with a letter.</div>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Label</label>
            <input type="text" class="form-control" name="label" id="rd-label" required>
          </div>
          <div class="row g-3 mb-3">
            <div class="col">
              <label class="form-label fw-semibold">Data Type</label>
              <select class="form-select" name="data_type" id="rd-data-type">
                {% for dt in ['string','text','integer','bigInteger','decimal','float','boolean','date','datetime','time','json','uuid','image','upload'] %}
                <option value="{{ dt }}">{{ dt }}</option>
                {% endfor %}
              </select>
            </div>
            <div class="col">
              <label class="form-label fw-semibold">Widget</label>
              <select class="form-select" name="widget" id="rd-widget">
                {% for w in ['text','textarea','number','select','checkbox','date','datetime','email','url','password','hidden','image','upload'] %}
                <option value="{{ w }}">{{ w }}</option>
                {% endfor %}
              </select>
            </div>
          </div>
          <div class="mb-3 d-none" id="rd-maxlen-group">
            <label class="form-label fw-semibold">Max length <small class="text-muted">(characters)</small></label>
            <input type="number" class="form-control" name="max_length" id="rd-max-length" min="1" max="65535" style="max-width:120px;">
          </div>
          <div class="mb-3 d-none" id="rd-options-group">
            <label class="form-label fw-semibold">Select Options <small class="text-muted">(one per line)</small></label>
            <textarea class="form-control font-monospace" name="options" id="rd-options" rows="4"></textarea>
          </div>
          <div class="d-flex align-items-center gap-2 mb-2">
            <label class="form-check-label mb-0" for="rd-is-indexed">Index this field</label>
            <input class="form-check-input mt-0" type="checkbox" name="is_indexed" id="rd-is-indexed" value="on">
          </div>
          {% if currentApp.database_mode === 'mysql' %}
          <div class="d-flex align-items-center gap-2" id="rd-fulltext-row">
            <label class="form-check-label mb-0" for="rd-is-fulltext">Fulltext index <span class="text-muted small">(MySQL only)</span></label>
            <input class="form-check-input mt-0" type="checkbox" name="is_fulltext_indexed" id="rd-is-fulltext" value="on">
          </div>
          {% endif %}
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Save Changes</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
(function () {
  const tbody = document.getElementById('fields-tbody');
  if (!tbody) return;

  let dragSrc = null;

  function getRows() {
    return [...tbody.querySelectorAll('tr.field-row')];
  }

  function clearDragStyles() {
    getRows().forEach(r => r.classList.remove('drag-over-top', 'drag-over-bottom', 'dragging'));
  }

  // Attach events to a row
  function initRow(tr) {
    tr.addEventListener('dragstart', function (e) {
      dragSrc = this;
      this.classList.add('dragging');
      e.dataTransfer.effectAllowed = 'move';
      e.dataTransfer.setData('text/plain', this.dataset.fieldId);
    });

    tr.addEventListener('dragend', function () {
      clearDragStyles();
      dragSrc = null;
    });

    tr.addEventListener('dragover', function (e) {
      e.preventDefault();
      if (this === dragSrc) return;
      clearDragStyles();
      dragSrc && dragSrc.classList.add('dragging');
      // Determine top or bottom half
      const rect = this.getBoundingClientRect();
      const mid  = rect.top + rect.height / 2;
      this.classList.add(e.clientY < mid ? 'drag-over-top' : 'drag-over-bottom');
      e.dataTransfer.dropEffect = 'move';
    });

    tr.addEventListener('dragleave', function () {
      this.classList.remove('drag-over-top', 'drag-over-bottom');
    });

    tr.addEventListener('drop', function (e) {
      e.preventDefault();
      e.stopPropagation();
      if (!dragSrc || dragSrc === this) return;

      const rect = this.getBoundingClientRect();
      const mid  = rect.top + rect.height / 2;
      const insertBefore = e.clientY < mid;

      if (insertBefore) {
        tbody.insertBefore(dragSrc, this);
      } else {
        this.nextSibling
          ? tbody.insertBefore(dragSrc, this.nextSibling)
          : tbody.appendChild(dragSrc);
      }

      clearDragStyles();
      updateSortNums();
      saveOrder();
    });
  }

  getRows().forEach(initRow);

  // ── Redefine modal ────────────────────────────────────────────────────────
  document.querySelectorAll('[data-redefine]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      const id      = btn.dataset.id;
      const options = btn.dataset.options || '';

      document.getElementById('redefineForm').action = '/admin/fields/' + id + '/redefine';
      document.getElementById('rd-field-name').value  = btn.dataset.name;
      document.getElementById('rd-label').value       = btn.dataset.label;
      document.getElementById('rd-data-type').value   = btn.dataset.type;
      document.getElementById('rd-widget').value      = btn.dataset.widget;
      document.getElementById('rd-is-indexed').checked = btn.dataset.indexed === 'true';
      const ftEl  = document.getElementById('rd-is-fulltext');
      const ftRow = document.getElementById('rd-fulltext-row');
      if (ftEl && ftRow) {
        const isText = btn.dataset.type === 'string' || btn.dataset.type === 'text';
        ftRow.classList.toggle('d-none', !isText);
        ftEl.checked = isText && btn.dataset.fulltext === 'true';
      }

      // Populate options / max_length from ui_options_json
      const optGroup    = document.getElementById('rd-options-group');
      const optArea     = document.getElementById('rd-options');
      const maxLenGroup = document.getElementById('rd-maxlen-group');
      const maxLenInput = document.getElementById('rd-max-length');
      const widget      = btn.dataset.widget;
      const TEXT_LIKE   = ['text','number','email','url','password'];
      try {
        const parsed = options ? JSON.parse(options) : {};
        if (parsed.options && Array.isArray(parsed.options)) {
          optArea.value = parsed.options.join('\n');
          optGroup.classList.remove('d-none');
        } else {
          optArea.value = '';
          optGroup.classList.add('d-none');
        }
        if (maxLenInput) maxLenInput.value = parsed.max_length || '';
      } catch { optArea.value = ''; optGroup.classList.add('d-none'); if (maxLenInput) maxLenInput.value = ''; }
      if (maxLenGroup) maxLenGroup.classList.toggle('d-none', !TEXT_LIKE.includes(widget));

      new bootstrap.Modal(document.getElementById('redefineModal')).show();
    });
  });

  // Show/hide options textarea and max_length when widget changes
  const TEXT_LIKE = ['text','number','email','url','password'];
  document.getElementById('rd-widget').addEventListener('change', function () {
    const optGroup    = document.getElementById('rd-options-group');
    const maxLenGroup = document.getElementById('rd-maxlen-group');
    optGroup.classList.toggle('d-none', this.value !== 'select');
    if (maxLenGroup) maxLenGroup.classList.toggle('d-none', !TEXT_LIKE.includes(this.value));
  });

  // Show/hide fulltext checkbox when data type changes
  const rdDataType = document.getElementById('rd-data-type');
  const rdFtRow    = document.getElementById('rd-fulltext-row');
  const rdFtEl     = document.getElementById('rd-is-fulltext');
  if (rdDataType && rdFtRow) {
    rdDataType.addEventListener('change', function () {
      const isText = this.value === 'string' || this.value === 'text';
      rdFtRow.classList.toggle('d-none', !isText);
      if (!isText && rdFtEl) rdFtEl.checked = false;
    });
  }

  function updateSortNums() {
    getRows().forEach((tr, i) => {
      const cell = tr.querySelector('.sort-num');
      if (cell) cell.textContent = i;
    });
  }

  let saveTimer = null;
  function saveOrder() {
    clearTimeout(saveTimer);
    saveTimer = setTimeout(async () => {
      const order = getRows().map((tr, i) => ({
        id:         parseInt(tr.dataset.fieldId, 10),
        sort_order: i
      }));
      try {
        const res = await fetch('/admin/fields/reorder', {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body:    JSON.stringify({ order })
        });
        if (!res.ok) throw new Error('server error');
        flashSaved();
      } catch (err) {
        console.error('Reorder failed:', err);
      }
    }, 300);
  }

  function flashSaved() {
    const el = document.getElementById('save-indicator');
    el.classList.add('visible');
    setTimeout(() => el.classList.remove('visible'), 1800);
  }
})();
</script>
{% endblock %}
