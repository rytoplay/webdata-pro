{% extends "admin/layout.njk" %}

{% block content %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/codemirror.min.css">
<style>
  .CodeMirror { height: auto; font-size: 0.8rem; font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace; border: 1px solid #dee2e6; border-radius: 0.375rem; }
  .CodeMirror-scroll { min-height: 580px; }
  .sql-cm .CodeMirror { border-radius: 0; border: none; }
  .sql-cm .CodeMirror-scroll { min-height: 200px; max-height: 200px; }
  .cm-review-marker { background: #fff3cd; border-left: 4px solid #fd7e14; display: block; }
</style>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/codemirror.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/mode/xml/xml.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/mode/javascript/javascript.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/mode/css/css.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/mode/htmlmixed/htmlmixed.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/mode/sql/sql.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/js-beautify/1.15.1/beautify-html.min.js"></script>
<div class="page-header">
  <h1>{{ view.label }} <span class="text-muted fw-normal fs-6">/ templates</span></h1>
  <div class="d-flex gap-2">
    <button type="button" id="btn-ai-design" class="btn btn-sm btn-warning"
      data-bs-toggle="modal" data-bs-target="#aiModal">
      <i class="bi bi-stars me-1"></i>AI Design
    </button>
    <a href="/admin/views/{{ view.id }}/edit" class="btn btn-sm btn-outline-secondary">
      <i class="bi bi-gear me-1"></i>Settings
    </a>
    <button type="button" id="btn-live-preview" class="btn btn-sm btn-outline-primary">
      <i class="bi bi-layout-sidebar me-1"></i>Live Preview
    </button>
    <a href="/admin/views/{{ view.id }}/preview" class="btn btn-sm btn-outline-secondary">
      <i class="bi bi-play me-1"></i>Preview
    </a>
    <a href="/admin/views" class="btn btn-sm btn-outline-secondary">&larr; Views</a>
  </div>
</div>

{% if flash %}
<div class="alert alert-{{ flash.type }} alert-dismissible fade show">
  {{ flash.message }}
  <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
{% endif %}

<!-- ── AI Fix Bar (shown when preview returns an error) ──────────────────── -->
<div id="fix-bar" style="display:none; background:#fef2f2; border:1px solid #fecaca; border-radius:10px;
     padding:0.75rem 1rem; margin-bottom:1rem; display:none; align-items:flex-start; gap:0.75rem;">
  <i class="bi bi-exclamation-triangle-fill text-danger mt-1" style="flex-shrink:0;"></i>
  <div style="flex:1; min-width:0;">
    <div style="font-weight:700; font-size:0.85rem; color:#991b1b; margin-bottom:0.2rem;">Preview error</div>
    <div id="fix-bar-msg" style="font-family:monospace; font-size:0.78rem; color:#7f1d1d;
         white-space:pre-wrap; word-break:break-all; max-height:80px; overflow:auto;"></div>
  </div>
  <button type="button" id="btn-ai-fix" class="btn btn-sm btn-danger" style="flex-shrink:0; white-space:nowrap;">
    <i class="bi bi-stars me-1"></i>Fix it
  </button>
  <div id="fix-bar-status" style="font-size:0.8rem; color:#64748b; align-self:center; display:none;"></div>
</div>

<form method="POST" action="/admin/views/{{ view.id }}/templates" id="editor-form">

  {# Hidden SQL mode fields — updated by JS #}
  <input type="hidden" name="query_mode" id="query_mode_input" value="{{ view.query_mode }}">
  <input type="hidden" name="custom_sql"  id="custom_sql_input"  value="{{ view.custom_sql or '' }}">

  <div class="row g-3">

    {# ── Left: template selector ── #}
    <div class="col-lg-2">
      <div class="list-group" id="tpl-selector">
        {% for type in templateTypes %}
        {% if type === 'edit_form' %}
        <div class="list-group-item py-1 px-3 border-0"
          style="font-size:0.68rem; font-weight:700; letter-spacing:0.07em; text-transform:uppercase; color:var(--text-muted); background:var(--bg-subtle, #f8f9fa); pointer-events:none;">
          Member Templates
        </div>
        {% endif %}
        <button type="button"
          class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-2 px-3
                 {% if loop.first %}active{% endif %}"
          data-tpl="{{ type }}" style="font-size:0.82rem;">
          {{ templateLabels[type] }}
        </button>
        {% endfor %}
      </div>
    </div>

    {# ── Center + drag handle + right panel ── #}
    <div class="col-lg-10 p-0" id="editor-right-wrap" style="display:flex;align-items:flex-start;gap:0;padding-left:calc(var(--bs-gutter-x)*0.5);">
    <div id="tpl-editor-col" style="flex:1 1 auto;min-width:200px;overflow:hidden;padding-right:6px;">
      {% for type in templateTypes %}
      <div class="tpl-panel {% if not loop.first %}d-none{% endif %}" data-tpl="{{ type }}">
        <div class="d-flex align-items-center justify-content-between mb-1">
          <label class="form-label mb-0 fw-semibold">{{ templateLabels[type] }}</label>
          <span class="text-muted small">HTML — use <code>\${token}</code> for values</span>
        </div>
        <textarea name="{{ type }}" class="form-control font-monospace tpl-textarea"
          data-tpl="{{ type }}" rows="16"
          style="font-size:0.8rem;resize:vertical;">{{ templates[type] | escape }}</textarea>
      </div>
      {% endfor %}
    </div>{# /tpl-editor-col #}

      <div id="editor-drag-handle" title="Drag to resize"
        style="flex:0 0 10px;align-self:stretch;cursor:col-resize;display:flex;align-items:center;justify-content:center;margin:0 1px;">
        <div id="editor-drag-pip" style="width:3px;height:48px;background:#cbd5e1;border-radius:2px;pointer-events:none;transition:background 0.15s;"></div>
      </div>

      {# ── Right: field picker ── #}
      <div id="tpl-panel-col" style="flex:0 0 280px;min-width:160px;max-width:540px;padding-right:calc(var(--bs-gutter-x)*0.5);">
      <div class="card shadow-sm h-100" style="font-size:0.8rem;">
        <div class="card-header p-0" style="border-bottom:1px solid #e2e8f0;">
          <div class="d-flex align-items-center justify-content-between ps-1 pe-2" style="padding-top:5px;">
            <div class="d-flex" style="gap:0;">
              <button type="button" class="panel-tab-btn" data-panel="tags"
                style="background:none;border:none;border-bottom:2px solid var(--accent);color:var(--accent);font-weight:600;font-size:0.78rem;cursor:pointer;padding:2px 12px 5px;">
                Tags
              </button>
              <button type="button" class="panel-tab-btn" data-panel="blocks"
                style="background:none;border:none;border-bottom:2px solid transparent;color:#64748b;font-weight:400;font-size:0.78rem;cursor:pointer;padding:2px 12px 5px;">
                Blocks
              </button>
            </div>
            <div class="d-flex gap-1">
              <button type="button" id="help-toggle" title="Show / hide quick help"
                style="background:none;border:1px solid #cbd5e1;border-radius:4px;color:#64748b;font-size:0.72rem;padding:1px 7px;cursor:pointer;line-height:1.6;">
                ? Help
              </button>
              <button type="button" id="help-fullscreen" title="Open full designer reference"
                data-bs-toggle="modal" data-bs-target="#designerRefModal"
                style="background:none;border:1px solid #cbd5e1;border-radius:4px;color:#64748b;font-size:0.72rem;padding:1px 7px;cursor:pointer;line-height:1.6;">
                <i class="bi bi-arrows-fullscreen"></i>
              </button>
            </div>
          </div>
        </div>
        <div id="help-panel" class="d-none" style="font-size:0.78rem;line-height:1.55;max-height:400px;overflow-y:auto;background:#f8fafc;border-bottom:1px solid #e2e8f0;"></div>
        <div id="panel-tags" class="card-body p-2" style="overflow-y:scroll;max-height:560px;scrollbar-width:thin;scrollbar-color:#cbd5e1 transparent;">

          <div id="search-hint" class="d-none mb-2 p-2 rounded" style="font-size:0.7rem;background:#dcfce7;color:#166534;line-height:1.4;">
            Click <code>$search[…]</code> to insert an auto-rendered search input based on the field type defined in Fields.
          </div>
          <div id="update-hint" class="d-none mb-2 p-2 rounded" style="font-size:0.7rem;background:#fef9c3;color:#713f12;line-height:1.4;">
            Click <code>$update[…]</code> to insert an auto-rendered input widget based on the field type defined in Fields.
          </div>

          {% if baseFields.length %}
          <div class="text-muted small mb-1" style="font-size:0.7rem;">BASE TABLE — {{ baseTable.table_name }}</div>
          {% for f in baseFields %}
          <button type="button" class="btn btn-sm w-100 text-start mb-1 token-btn"
            data-token="${{ '{' }}{{ baseTable.table_name }}.{{ f.field_name }}{{ '}' }}"
            style="background:var(--accent-soft);color:var(--accent);border:none;font-family:monospace;font-size:0.75rem;padding:2px 6px;">
            ${{ '{' }}{{ baseTable.table_name }}.{{ f.field_name }}{{ '}' }}
          </button>
          <div class="search-token-btn d-none mb-1" style="display:flex;gap:3px;align-items:stretch;">
            <button type="button" class="token-btn" data-token="$search[{{ baseTable.table_name }}.{{ f.field_name }}]"
              style="flex:1;min-width:0;text-align:left;background:#dcfce7;color:#166534;border:none;font-family:monospace;font-size:0.75rem;padding:2px 6px 2px 16px;border-radius:3px;cursor:pointer;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
              $search[{{ baseTable.table_name }}.{{ f.field_name }}]
            </button>
            <button type="button" class="token-btn" data-token='name="{{ baseTable.table_name }}__{{ f.field_name }}"'
              title='Insert: name="{{ baseTable.table_name }}__{{ f.field_name }}"'
              style="flex-shrink:0;background:#f0fdf4;color:#166534;border:1px dashed #86efac;font-family:monospace;font-size:0.65rem;padding:1px 5px;border-radius:3px;cursor:pointer;white-space:nowrap;">
              name
            </button>
          </div>
          <div class="update-token-btn d-none mb-1" style="display:flex;gap:3px;align-items:stretch;">
            <button type="button" class="token-btn" data-token="$update[{{ baseTable.table_name }}.{{ f.field_name }}]"
              style="flex:1;min-width:0;text-align:left;background:#dbeafe;color:#1e40af;border:none;font-family:monospace;font-size:0.75rem;padding:2px 6px 2px 16px;border-radius:3px;cursor:pointer;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
              $update[{{ baseTable.table_name }}.{{ f.field_name }}]
            </button>
            <button type="button" class="token-btn" data-token='name="{{ f.field_name }}"'
              title='Insert: name="{{ f.field_name }}"'
              style="flex-shrink:0;background:#eff6ff;color:#1e40af;border:1px dashed #93c5fd;font-family:monospace;font-size:0.65rem;padding:1px 5px;border-radius:3px;cursor:pointer;white-space:nowrap;">
              name
            </button>
          </div>
          {% endfor %}
          {% endif %}

          {% if joinedFields.length %}
          <div class="text-muted small mt-2 mb-1" style="font-size:0.7rem;">JOINED TABLES</div>
          {% for f in joinedFields %}
          <button type="button" class="btn btn-sm w-100 text-start mb-1 token-btn"
            data-token="${{ '{' }}{{ f.table_name }}.{{ f.field_name }}{{ '}' }}"
            style="background:#f0fdf4;color:#166534;border:none;font-family:monospace;font-size:0.75rem;padding:2px 6px;">
            ${{ '{' }}{{ f.table_name }}.{{ f.field_name }}{{ '}' }}
          </button>
          <div class="search-token-btn d-none mb-1" style="display:flex;gap:3px;align-items:stretch;">
            <button type="button" class="token-btn" data-token="$search[{{ f.table_name }}.{{ f.field_name }}]"
              style="flex:1;min-width:0;text-align:left;background:#dcfce7;color:#166534;border:none;font-family:monospace;font-size:0.75rem;padding:2px 6px 2px 16px;border-radius:3px;cursor:pointer;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
              $search[{{ f.table_name }}.{{ f.field_name }}]
            </button>
            <button type="button" class="token-btn" data-token='name="{{ f.table_name }}__{{ f.field_name }}"'
              title='Insert: name="{{ f.table_name }}__{{ f.field_name }}"'
              style="flex-shrink:0;background:#f0fdf4;color:#166534;border:1px dashed #86efac;font-family:monospace;font-size:0.65rem;padding:1px 5px;border-radius:3px;cursor:pointer;white-space:nowrap;">
              name
            </button>
          </div>
          <div class="update-token-btn d-none mb-1" style="display:flex;gap:3px;align-items:stretch;">
            <button type="button" class="token-btn" data-token="$update[{{ f.table_name }}.{{ f.field_name }}]"
              style="flex:1;min-width:0;text-align:left;background:#dbeafe;color:#1e40af;border:none;font-family:monospace;font-size:0.75rem;padding:2px 6px 2px 16px;border-radius:3px;cursor:pointer;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
              $update[{{ f.table_name }}.{{ f.field_name }}]
            </button>
            <button type="button" class="token-btn" data-token='name="{{ f.field_name }}"'
              title='Insert: name="{{ f.field_name }}"'
              style="flex-shrink:0;background:#eff6ff;color:#1e40af;border:1px dashed #93c5fd;font-family:monospace;font-size:0.65rem;padding:1px 5px;border-radius:3px;cursor:pointer;white-space:nowrap;">
              name
            </button>
          </div>
          {% endfor %}
          {% endif %}

          <div class="text-muted small mt-2 mb-1" style="font-size:0.7rem;">SYSTEM TOKENS</div>
          {% set sysTokens = [
            ['_pk',          'Primary key of this row',              'row · detail · edit_form'],
            ['_row_num',     'Row number (1, 2, 3…)',                'row · header'],
            ['_q',           'Current search term',                  'search_form · header'],
            ['_page',        'Current page number',                  'footer · header'],
            ['_total',       'Total matching records',               'header · footer · search_form'],
            ['_total_pages', 'Total page count',                     'footer'],
            ['_has_prev',    'Non-empty if a prev page exists',      'footer'],
            ['_has_next',    'Non-empty if a next page exists',      'footer'],
            ['_prev_page',   'Previous page number',                 'footer'],
            ['_next_page',   'Next page number',                     'footer'],
            ['_pagination',  'Auto Prev / Page N / Next widget',    'footer'],
            ['_sort',        'Active sort column name',              'header · row'],
            ['_dir',         '"asc" or "desc"',                      'header · row'],
            ['_group_value', 'Value of the current group',          'group_header · group_footer']
          ] %}
          {% for tok in sysTokens %}
          <button type="button" class="btn btn-sm w-100 text-start mb-1 token-btn"
            data-token="${{ '{' }}{{ tok[0] }}{{ '}' }}"
            style="background:#fff3cd;color:#664d03;border:none;padding:3px 6px;line-height:1.2;">
            <div style="font-family:monospace;font-size:0.75rem;">${{ '{' }}{{ tok[0] }}{{ '}' }}</div>
            <div style="font-family:system-ui,sans-serif;font-size:0.62rem;color:#92400e;opacity:0.85;margin-top:1px;">{{ tok[1] }}</div>
            <div style="font-family:system-ui,sans-serif;font-size:0.6rem;color:#b45309;opacity:0.65;font-style:italic;">{{ tok[2] }}</div>
          </button>
          {% endfor %}

          <div class="text-muted small mt-2 mb-1" style="font-size:0.7rem;">INTERACTION ATTRIBUTES</div>
          {% set iAttrs = [
            [['data-wdp-action="detail"','data-wdp-id="${_pk}"'], 'Click → open detail view',          'row'],
            [['data-wdp-action="edit"',  'data-wdp-id="${_pk}"'], 'Click → open edit form',            'row · detail'],
            [['data-wdp-action="back"'],                          'Click → return to list',            'detail · edit_form'],
            [['data-wdp-action="clear"'],                         'Click → clear all search filters',  'search_form'],
            [['data-wdp-action="page"','data-wdp-page="${…}"'],   'Click → navigate to that page',    'footer'],
            [['data-wdp-action="sort"','data-wdp-field="col"'],   'Click → sort by column (asc/desc)', 'header · row'],
            [['data-wdp-form="search"  (on form)'],               'Required: marks the search form',   'search_form'],
            [['data-wdp-form="edit"','data-wdp-id="${_pk}"  (on form)'], 'Required: marks the edit form', 'edit_form'],
            [['$update[table.field]'],                            'Auto-renders input widget, pre-filled', 'edit_form'],
            [['$gallery[table_photos]'],                          'Photo gallery widget (view + upload)',  'detail · edit_form']
          ] %}
          {% for ia in iAttrs %}
          <div class="mb-1 px-2 py-1 rounded" style="background:#eff6ff;color:#1e3a8a;line-height:1.25;">
            {% for line in ia[0] %}
            <div style="font-family:monospace;font-size:0.7rem;">{{ line }}</div>
            {% endfor %}
            <div style="font-size:0.62rem;color:#1d4ed8;margin-top:2px;">{{ ia[1] }}</div>
            <div style="font-size:0.59rem;color:#6b7280;font-style:italic;">{{ ia[2] }}</div>
          </div>
          {% endfor %}

          <div class="text-muted small mt-2 mb-1" style="font-size:0.7rem;">TEMPLATE TAGS</div>
          <div style="font-size:0.72rem;color:#6b7280;line-height:1.6;">
            <div class="mb-1"><strong style="color:#374151;">$if()</strong> — conditional output</div>
            <code style="font-size:0.7rem;word-break:break-all;">$if(field &gt; value, "true html", "false html")</code>
            <div class="text-muted mt-1 mb-2" style="font-size:0.68rem;">
              Operators: <code>&gt; &lt; &gt;= &lt;= == != &lt;&gt;</code><br>
              Wrap branch values in quotes if they contain commas.<br>
              Branches may contain <code>\${...}</code> tokens.
            </div>
            <div class="mb-1"><strong style="color:#374151;">&lt;group&gt;</strong> — multi-row concat</div>
            <code style="font-size:0.7rem;word-break:break-all;">&lt;group delimiter=", "&gt;\${authors.first_name} \${authors.last_name}&lt;/group&gt;</code>
            <div class="text-muted mt-1" style="font-size:0.68rem;">
              Groups joined rows into a single delimited value via SQL GROUP_CONCAT.
            </div>
          </div>

          <div class="d-flex justify-content-between align-items-center mt-3 mb-1">
            <span class="text-muted" style="font-size:0.7rem;">CSS CLASSES — CHEAT SHEET</span>
            <button type="button" id="cheat-expand" title="Open larger view" data-bs-toggle="modal" data-bs-target="#cheatModal"
              style="background:none;border:1px solid #cbd5e1;border-radius:4px;color:#64748b;font-size:0.65rem;padding:1px 6px;cursor:pointer;line-height:1.6;">
              <i class="bi bi-arrows-fullscreen"></i>
            </button>
          </div>
          <pre id="css-cheat" style="font-size:0.64rem;line-height:1.5;background:#f1f5f9;border:1px solid #e2e8f0;border-radius:4px;padding:6px 8px;color:#1e293b;overflow-x:auto;white-space:pre;margin:0;font-family:'SFMono-Regular',Consolas,monospace;min-height:80px;max-height:220px;overflow-y:auto;resize:vertical;scrollbar-width:thin;scrollbar-color:#cbd5e1 transparent;"></pre>
        </div>{# /panel-tags #}

        {# ── Blocks pane ───────────────────────────────────────────────── #}
        <div id="panel-blocks" class="card-body p-2 d-none" style="overflow-y:auto;max-height:560px;scrollbar-width:thin;scrollbar-color:#cbd5e1 transparent;">

          <div class="text-muted mb-2" style="font-size:0.7rem;">A — COMPLETE SCAFFOLDS</div>

          <button type="button" class="block-btn w-100 text-start mb-2 p-2 rounded" data-block="search-form"
            style="background:#f0fdf4;border:1px solid #86efac;cursor:pointer;">
            <div style="font-weight:600;font-size:0.78rem;color:#166534;">Search Form</div>
            <div style="font-size:0.67rem;color:#4b7c59;margin-top:2px;">form · dropdowns · keyword input · Search / Clear</div>
          </button>

          <button type="button" class="block-btn w-100 text-start mb-2 p-2 rounded" data-block="results-row"
            style="background:#f0fdf4;border:1px solid #86efac;cursor:pointer;">
            <div style="font-weight:600;font-size:0.78rem;color:#166534;">Results Row</div>
            <div style="font-size:0.67rem;color:#4b7c59;margin-top:2px;">clickable wdp-row · title / sub / meta + arrow</div>
          </button>

          <button type="button" class="block-btn w-100 text-start mb-2 p-2 rounded" data-block="detail-view"
            style="background:#f0fdf4;border:1px solid #86efac;cursor:pointer;">
            <div style="font-weight:600;font-size:0.78rem;color:#166534;">Detail View</div>
            <div style="font-size:0.67rem;color:#4b7c59;margin-top:2px;">back button · title · sub · field list</div>
          </button>

          <div class="text-muted mt-3 mb-2" style="font-size:0.7rem;">C — COMPOUND SNIPPETS</div>

          <button type="button" class="block-btn w-100 text-start mb-2 p-2 rounded" data-block="field-label-value"
            style="background:#eff6ff;border:1px solid #93c5fd;cursor:pointer;">
            <div style="font-weight:600;font-size:0.78rem;color:#1e40af;">Field: label + value</div>
            <div style="font-size:0.67rem;color:#3b5fa0;margin-top:2px;">wdp-field · wdp-field-label · wdp-field-value</div>
          </button>

          <button type="button" class="block-btn w-100 text-start mb-2 p-2 rounded" data-block="image-info-card"
            style="background:#eff6ff;border:1px solid #93c5fd;cursor:pointer;">
            <div style="font-weight:600;font-size:0.78rem;color:#1e40af;">Image + Info Card</div>
            <div style="font-size:0.67rem;color:#3b5fa0;margin-top:2px;">thumbnail · title · subtext side by side</div>
          </button>

          <button type="button" class="block-btn w-100 text-start mb-2 p-2 rounded" data-block="section-heading"
            style="background:#eff6ff;border:1px solid #93c5fd;cursor:pointer;">
            <div style="font-weight:600;font-size:0.78rem;color:#1e40af;">Section Heading</div>
            <div style="font-size:0.67rem;color:#3b5fa0;margin-top:2px;">styled uppercase divider label</div>
          </button>

          <button type="button" class="block-btn w-100 text-start mb-2 p-2 rounded" data-block="pagination"
            style="background:#eff6ff;border:1px solid #93c5fd;cursor:pointer;">
            <div style="font-weight:600;font-size:0.78rem;color:#1e40af;">Pagination Footer</div>
            <div style="font-size:0.67rem;color:#3b5fa0;margin-top:2px;">wdp-footer · ${_pagination}</div>
          </button>

          <div class="text-muted mt-3 mb-2" style="font-size:0.7rem;">B — INDIVIDUAL ELEMENTS</div>

          {% set indivBlocks = [
            ['search-form-tag', '&lt;form data-wdp-form="search"&gt;', 'marks the search form'],
            ['adv-fields',      'wdp-adv-fields',                       'search fields container'],
            ['adv-btns',        'wdp-adv-btns',                         'Search + Clear buttons'],
            ['wdp-field-div',   'wdp-field',                            'field wrapper div'],
            ['wdp-row-div',     'wdp-row',                              'list row wrapper'],
            ['wdp-surface-div', 'wdp-surface',                          'card / panel surface'],
            ['wdp-detail-div',  'wdp-detail',                           'detail view wrapper']
          ] %}
          {% for b in indivBlocks %}
          <button type="button" class="block-btn w-100 text-start mb-1 p-2 rounded" data-block="{{ b[0] }}"
            style="background:#f8fafc;border:1px solid #e2e8f0;cursor:pointer;">
            <div style="font-family:monospace;font-size:0.75rem;color:#374151;">{{ b[1] }}</div>
            <div style="font-size:0.65rem;color:#9ca3af;margin-top:1px;">{{ b[2] }}</div>
          </button>
          {% endfor %}

        </div>{# /panel-blocks #}
      </div>
      </div>{# /tpl-panel-col #}
    </div>{# /editor-right-wrap #}
  </div>

  {# ── SQL section ── #}
  <div class="card shadow-sm mt-3">
    <div class="card-header d-flex align-items-center justify-content-between py-2" style="cursor:pointer;" id="sql-card-header">
      <span>
        <i class="bi bi-chevron-{{ 'down' if view.query_mode == 'advanced_sql' else 'right' }} me-1 text-muted" id="sql-chevron" style="font-size:0.8rem;transition:transform 0.15s;"></i>
        <i class="bi bi-terminal me-2"></i><strong>Query SQL</strong>
        <span id="sql-mode-badge" class="badge ms-2
          {{ 'bg-warning text-dark' if view.query_mode == 'advanced_sql' else 'bg-light text-dark border' }}">
          {{ 'Custom SQL' if view.query_mode == 'advanced_sql' else 'Auto-generated' }}
        </span>
      </span>
      <div class="d-flex gap-2" onclick="event.stopPropagation()">
        <button type="button" id="btn-refresh-sql" class="btn btn-sm btn-outline-secondary">
          <i class="bi bi-arrow-clockwise me-1"></i>Refresh SQL
        </button>
        <button type="button" id="btn-customize-sql" class="btn btn-sm btn-outline-warning"
          {% if view.query_mode == 'advanced_sql' %}style="display:none"{% endif %}>
          Customize SQL
        </button>
        <button type="button" id="btn-reset-sql" class="btn btn-sm btn-outline-secondary"
          {% if view.query_mode != 'advanced_sql' %}style="display:none"{% endif %}>
          Reset to Auto
        </button>
      </div>
    </div>
    <div id="sql-collapsible" {% if view.query_mode != 'advanced_sql' %}style="display:none"{% endif %}>
      <div class="card-body p-0 sql-cm">
        <textarea id="sql-editor" class="form-control font-monospace border-0 rounded-0"
          rows="8" style="font-size:0.8rem;resize:vertical;border-radius:0 !important;"
          {% if view.query_mode != 'advanced_sql' %}readonly{% endif %}>{{ view.custom_sql if view.query_mode == 'advanced_sql' else generatedSql }}</textarea>
      </div>
      <div class="card-footer py-2 text-muted small" id="sql-hint">
        {% if view.query_mode == 'advanced_sql' %}
        Custom SQL active. Column aliases become available as <code>\${alias}</code> tokens in templates.
        {% else %}
        Auto-generated from <code>\${table.field}</code> tokens found in your templates. Click <em>Customize SQL</em> to edit.
        {% endif %}
      </div>
    </div>
  </div>

  {# ── Save ── #}
  <div class="d-flex gap-2 mt-3 align-items-center">
    <button type="submit" class="btn btn-primary">
      <i class="bi bi-check-lg me-1"></i>Save All Templates
    </button>
    <a href="/admin/views/{{ view.id }}/edit" class="btn btn-outline-secondary">Settings</a>
    <span id="save-indicator" class="text-muted small ms-2" style="opacity:0;transition:opacity 0.4s;">Saved</span>
  </div>
</form>

{# ── AI Design modal ── #}
<div class="modal fade" id="aiModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-stars me-2"></i>AI Design</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
