      // Relay search/page/sort state to the editor window — editor does the fetch (has credentials)
      'function _relay(){if(window.opener&&!window.opener.closed)window.opener.postMessage({type:"wdp-search",st:_st.toString()},"*");}',

      // Bind submit handler directly to search forms after each innerHTML update
      'function _bindForm(){',
      '  document.querySelectorAll("[data-wdp-form=\'search\']").forEach(function(form){',
      '    if(form._wdpBound)return;',
      '    form._wdpBound=true;',
      '    form.addEventListener("submit",function(e){',
      '      e.preventDefault();',
      '      _st=new URLSearchParams({mode:"list",page:"1"});',
      '      var q=form.querySelector("[name=q]");',
      '      if(q&&q.value)_st.set("q",q.value);',
      '      new FormData(form).forEach(function(v,k){if(k!=="q"&&String(v).trim())_st.set("f_"+k,String(v));});',
      '      _relay();',
      '    });',
      '  });',
      '}',

      // Restore form field values from current _st after each re-render
      'function _restoreForm(){',
      '  var form=document.querySelector("[data-wdp-form=\'search\']");',
      '  if(!form)return;',
      '  _st.forEach(function(val,key){',
      '    if(key==="mode"||key==="page")return;',
      '    var fname=key.startsWith("f_")?key.slice(2):key;',
      '    var el=form.querySelector("[name=\\""+fname+"\\"]");',
      '    if(!el)return;',
      '    if(el.tagName==="SELECT"){for(var i=0;i<el.options.length;i++){if(el.options[i].value===val){el.selectedIndex=i;break;}}}',
      '    else if(el.type==="checkbox"){el.checked=(val==="on"||val==="1");}',
      '    else{el.value=val;}',
      '  });',
      '}',

      // Receive rendered HTML pushed back by editor
      'window.addEventListener("message",function(e){',
      '  if(!e.data||e.data.type!=="wdp-preview")return;',
      '  document.getElementById("wdp-status").classList.add("hidden");',
      '  document.getElementById("wdp-content").innerHTML=e.data.html;',
      '  if(e.data.sql!==undefined)_showSql(e.data.sql);',
      '  if(e.data.resetState)_st=new URLSearchParams({mode:"list",page:"1"});',
      '  _bindForm();',
      '  _restoreForm();',
      '});',

      // Pagination, sort, clear — relay to editor
      'document.addEventListener("click",function(e){',
      '  var el=e.target.closest("[data-wdp-action]");',
      '  if(!el)return;',
      '  var act=el.dataset.wdpAction;',
      '  if(act==="page"){e.preventDefault();_st.set("page",el.dataset.wdpPage||"1");_relay();}',
      '  else if(act==="clear"){e.preventDefault();_st=new URLSearchParams({mode:"list",page:"1"});_relay();}',
      '  else if(act==="sort"){e.preventDefault();var f=el.dataset.wdpField,d=(_st.get("sort")===f&&_st.get("dir")==="asc")?"desc":"asc";_st.set("sort",f);_st.set("dir",d);_st.set("page","1");_relay();}',
      '});',
      '<\/script>',
      '</body></html>'
    ];
    const blob = new Blob([lines.join('')], { type: 'text/html' });
    popupBlobUrl = URL.createObjectURL(blob);
    return popupBlobUrl;
  }

  function collectTemplates() {
    const data = {};
    const editors = window._wdpCmEditors;
    if (editors && Object.keys(editors).length) {
      Object.entries(editors).forEach(([key, editor]) => { data[key] = editor.getValue(); });
    } else {
      document.querySelectorAll('textarea[name]').forEach(ta => { data[ta.name] = ta.value; });
    }
    return data;
  }

  const fixBar     = document.getElementById('fix-bar');
  const fixBarMsg  = document.getElementById('fix-bar-msg');
  const fixBarStat = document.getElementById('fix-bar-status');

  function showFixBar(errorText) {
    fixBarMsg.textContent = errorText;
    fixBar.style.display  = 'flex';
  }

  function hideFixBar() {
    fixBar.style.display = 'none';
    fixBarMsg.textContent = '';
  }

  async function pushPreview() {
    if (!previewWin || previewWin.closed) return;
    try {
      const templates = collectTemplates();
      const res  = await fetch(RENDER_URL, {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify(templates),
      });
      const { html, sql, error } = await res.json();
      if (error) {
        showFixBar(error);
        previewWin.postMessage({ type: 'wdp-preview', html: '<p style="color:red;padding:12px;font-family:monospace">Error: ' + error + '</p>', sql: '' }, '*');
        return;
      }
      hideFixBar();
      // Pass rendered HTML and debug SQL; resetState clears popup's search state on fresh push
      previewWin.postMessage({ type: 'wdp-preview', html, sql, resetState: true }, '*');
    } catch (e) {
      previewWin.postMessage({ type: 'wdp-preview', html: '<p style="color:red;padding:12px;font-family:monospace">Request failed: ' + e.message + '</p>' }, '*');
    }
  }

  function schedulePush() {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(pushPreview, 450);
  }

  // CM editors trigger _wdpSchedulePush directly via their change events
  window._wdpSchedulePush = schedulePush;

  // Handle search/page/sort relayed from the preview popup
  // The popup can't make authenticated fetches from a blob URL, so it sends us the state
  // and we do the fetch (with full session credentials) then push the result back.
  window.addEventListener('message', async function(e) {
    if (!e.data || e.data.type !== 'wdp-search') return;
    if (!previewWin || previewWin.closed) return;
    try {
      const sqlCaptureSt = e.data.st;
      const res  = await fetch(RENDER_URL + '?' + sqlCaptureSt, {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify(collectTemplates()),
      });
      const { html, sql, error } = await res.json();
      if (error) showFixBar(error);
      else hideFixBar();
      previewWin.postMessage({ type: 'wdp-preview', html: html || '', sql: sql ?? '' }, '*');
    } catch (err) {
      previewWin.postMessage({ type: 'wdp-preview', html: '<p style="color:red;padding:12px;font-family:monospace">Request failed: ' + err.message + '</p>', sql: '' }, '*');
    }
  });

  document.getElementById('btn-live-preview').addEventListener('click', function() {
    if (!previewWin || previewWin.closed) {
      previewWin = window.open(getPopupUrl(), 'wdp-live-preview',
        'width=860,height=700,left=100,top=80,resizable=yes,scrollbars=yes');
      setTimeout(pushPreview, 800);
    } else {
      previewWin.focus();
      pushPreview();
    }
  });

  // ── Fix it button ────────────────────────────────────────────────────────────
  let fixAbortCtrl = null;

  document.getElementById('btn-ai-fix').addEventListener('click', async function() {
    const btn  = this;
    const errorText = fixBarMsg.textContent;
    if (!errorText) return;

    // If already running, cancel it
    if (fixAbortCtrl) {
      fixAbortCtrl.abort();
      fixAbortCtrl = null;
      btn.disabled = false;
      btn.innerHTML = '<i class="bi bi-stars me-1"></i>Fix it';
      fixBarStat.textContent = 'Cancelled.';
      return;
    }

    fixAbortCtrl = new AbortController();
    btn.disabled = false;  // keep enabled so user can click to cancel
    btn.innerHTML = '<i class="bi bi-stars me-1"></i>Cancel';
    btn.classList.replace('btn-danger', 'btn-outline-danger');
    fixBarStat.style.display = 'inline';
    fixBarStat.style.color   = '#64748b';
    fixBarStat.textContent   = '';

    let secs = 0;
    const timer = setInterval(() => {
      secs++;
      fixBarStat.textContent = `${secs}s — large models can take 1–2 min…`;
    }, 1000);

    try {
      // Only send templates that mention the error keywords — keeps payload small
      const allTpls = collectTemplates();
      const keywords = errorText.match(/[\w]+/g) || [];
      const trimmedTpls = {};
      for (const [k, v] of Object.entries(allTpls)) {
        if (!v) continue;
        // Always include; server will trim further if needed
        trimmedTpls[k] = v;
      }

      const payload = {
        ...trimmedTpls,
        error:      errorText,
        query_mode: document.getElementById('query_mode_input').value,
        custom_sql: document.getElementById('custom_sql_input').value,
      };

      const res  = await fetch('/admin/views/{{ view.id }}/ai-fix', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify(payload),
        signal:  fixAbortCtrl.signal,
      });
      const data = await res.json();

      if (data.error) {
        fixBarStat.textContent = '✗ ' + data.error;
        fixBarStat.style.color = '#991b1b';
      } else {
        // Apply fixed templates to CM editors
        const editors = window._wdpCmEditors || {};
        if (data.templates) {
          for (const [type, content] of Object.entries(data.templates)) {
            if (content && editors[type]) {
              const fmt = typeof html_beautify !== 'undefined'
                ? html_beautify(content, { indent_size: 2, wrap_line_length: 0, preserve_newlines: false })
                : content;
              editors[type].setValue(fmt);
            }
          }
        }
        // Apply fixed SQL
        if (data.custom_sql) {
          const sqlInput = document.getElementById('custom_sql_input');
          if (sqlInput) sqlInput.value = data.custom_sql;
          if (window._wdpSqlCm) window._wdpSqlCm.setValue(data.custom_sql);
        }

        fixBarStat.textContent = '✓ ' + (data.explanation || 'Fixed!');
        fixBarStat.style.color = '#166534';

        // Re-run preview so user sees the result immediately
        if (typeof window._wdpSchedulePush === 'function') window._wdpSchedulePush();
      }
    } catch (e) {
      if (e.name !== 'AbortError') {
        fixBarStat.textContent = '✗ ' + e.message;
        fixBarStat.style.color = '#991b1b';
      }
    } finally {
      clearInterval(timer);
      fixAbortCtrl = null;
      btn.disabled = false;
      btn.innerHTML = '<i class="bi bi-stars me-1"></i>Fix it';
      btn.classList.replace('btn-outline-danger', 'btn-danger');
    }
  });
})();

// ── Editor / panel drag resize ────────────────────────────────────────────────
(function() {
  const handle    = document.getElementById('editor-drag-handle');
  const pip       = document.getElementById('editor-drag-pip');
  const editorCol = document.getElementById('tpl-editor-col');
  const panelCol  = document.getElementById('tpl-panel-col');
  const wrap      = document.getElementById('editor-right-wrap');
  if (!handle || !editorCol || !panelCol || !wrap) return;

  const PREF_KEY = 'wdp_panel_w_{{ view.id }}';

  function setPanelWidth(w) {
    w = Math.max(160, Math.min(540, w));
    panelCol.style.flexBasis = w + 'px';
    // Nudge CM editors to re-measure their width
    Object.values(window._wdpCmEditors || {}).forEach(cm => cm.refresh());
  }

  // Restore saved preference
  try {
    const saved = localStorage.getItem(PREF_KEY);
    if (saved) setPanelWidth(parseFloat(saved));
  } catch(e) {}

  let dragging = false, startX = 0, startW = 0;

  handle.addEventListener('mousedown', function(e) {
    e.preventDefault();
    dragging = true;
    startX = e.clientX;
    startW = panelCol.getBoundingClientRect().width;
    document.body.style.cursor     = 'col-resize';
    document.body.style.userSelect = 'none';
    if (pip) pip.style.background  = '#64748b';
  });

  document.addEventListener('mousemove', function(e) {
    if (!dragging) return;
    const dx  = startX - e.clientX;   // drag left → panel gets wider
    setPanelWidth(startW + dx);
  });

  document.addEventListener('mouseup', function() {
    if (!dragging) return;
    dragging = false;
    document.body.style.cursor     = '';
    document.body.style.userSelect = '';
    if (pip) pip.style.background  = '';
    try { localStorage.setItem(PREF_KEY, panelCol.getBoundingClientRect().width.toFixed(0)); } catch(e) {}
  });

  handle.addEventListener('mouseenter', function() { if (pip) pip.style.background = '#94a3b8'; });
  handle.addEventListener('mouseleave', function() { if (!dragging && pip) pip.style.background = ''; });
}());
</script>
{% endblock %}
