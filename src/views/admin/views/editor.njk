{% extends "admin/layout.njk" %}

{% block content %}
<div class="page-header">
  <h1>{{ view.label }} <span class="text-muted fw-normal fs-6">/ templates</span></h1>
  <div class="d-flex gap-2">
    <button type="button" id="btn-ai-design" class="btn btn-sm btn-warning"
      data-bs-toggle="modal" data-bs-target="#aiModal">
      <i class="bi bi-stars me-1"></i>AI Design
    </button>
    <a href="/admin/views/{{ view.id }}/edit" class="btn btn-sm btn-outline-secondary">
      <i class="bi bi-gear me-1"></i>Settings
    </a>
    <button type="button" id="btn-live-preview" class="btn btn-sm btn-outline-primary">
      <i class="bi bi-layout-sidebar me-1"></i>Live Preview
    </button>
    <a href="/admin/views/{{ view.id }}/preview" class="btn btn-sm btn-outline-secondary">
      <i class="bi bi-play me-1"></i>Preview
    </a>
    <a href="/admin/views" class="btn btn-sm btn-outline-secondary">&larr; Views</a>
  </div>
</div>

{% if flash %}
<div class="alert alert-{{ flash.type }} alert-dismissible fade show">
  {{ flash.message }}
  <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
{% endif %}

<form method="POST" action="/admin/views/{{ view.id }}/templates" id="editor-form">

  {# Hidden SQL mode fields — updated by JS #}
  <input type="hidden" name="query_mode" id="query_mode_input" value="{{ view.query_mode }}">
  <input type="hidden" name="custom_sql"  id="custom_sql_input"  value="{{ view.custom_sql or '' }}">

  <div class="row g-3">

    {# ── Left: template selector ── #}
    <div class="col-lg-2">
      <div class="list-group" id="tpl-selector">
        {% for type in templateTypes %}
        <button type="button"
          class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-2 px-3
                 {% if loop.first %}active{% endif %}"
          data-tpl="{{ type }}" style="font-size:0.82rem;">
          {{ templateLabels[type] }}
        </button>
        {% endfor %}
      </div>
    </div>

    {# ── Center: editor + right: field picker ── #}
    <div class="col-lg-7">
      {% for type in templateTypes %}
      <div class="tpl-panel {% if not loop.first %}d-none{% endif %}" data-tpl="{{ type }}">
        <div class="d-flex align-items-center justify-content-between mb-1">
          <label class="form-label mb-0 fw-semibold">{{ templateLabels[type] }}</label>
          <span class="text-muted small">HTML — use <code>\${token}</code> for values</span>
        </div>
        <textarea name="{{ type }}" class="form-control font-monospace tpl-textarea"
          data-tpl="{{ type }}" rows="16"
          style="font-size:0.8rem;resize:vertical;">{{ templates[type] | escape }}</textarea>
      </div>
      {% endfor %}
    </div>

    {# ── Right: field picker ── #}
    <div class="col-lg-3">
      <div class="card shadow-sm h-100" style="font-size:0.8rem;">
        <div class="card-header py-2 d-flex justify-content-between align-items-center">
          <strong>Field tokens</strong>
          <div class="d-flex gap-1">
            <button type="button" id="help-toggle" title="Show / hide quick help"
              style="background:none;border:1px solid #cbd5e1;border-radius:4px;color:#64748b;font-size:0.72rem;padding:1px 7px;cursor:pointer;line-height:1.6;">
              ? Help
            </button>
            <button type="button" id="help-fullscreen" title="Open full designer reference"
              data-bs-toggle="modal" data-bs-target="#designerRefModal"
              style="background:none;border:1px solid #cbd5e1;border-radius:4px;color:#64748b;font-size:0.72rem;padding:1px 7px;cursor:pointer;line-height:1.6;">
              <i class="bi bi-arrows-fullscreen"></i>
            </button>
          </div>
        </div>
        <div id="help-panel" class="d-none" style="font-size:0.78rem;line-height:1.55;max-height:400px;overflow-y:auto;background:#f8fafc;border-bottom:1px solid #e2e8f0;"></div>
        <div class="card-body p-2" style="overflow-y:auto;max-height:420px;">

          <div id="search-hint" class="d-none mb-2 p-2 rounded" style="font-size:0.7rem;background:#dcfce7;color:#166534;line-height:1.4;">
            Click <code>$search[…]</code> to insert an auto-rendered search input based on the field type defined in Fields.
          </div>
          <div id="update-hint" class="d-none mb-2 p-2 rounded" style="font-size:0.7rem;background:#fef9c3;color:#713f12;line-height:1.4;">
            Click <code>$update[…]</code> to insert an auto-rendered input widget based on the field type defined in Fields.
          </div>

          {% if baseFields.length %}
          <div class="text-muted small mb-1" style="font-size:0.7rem;">BASE TABLE — {{ baseTable.table_name }}</div>
          {% for f in baseFields %}
          <button type="button" class="btn btn-sm w-100 text-start mb-1 token-btn"
            data-token="${{ '{' }}{{ baseTable.table_name }}.{{ f.field_name }}{{ '}' }}"
            style="background:var(--accent-soft);color:var(--accent);border:none;font-family:monospace;font-size:0.75rem;padding:2px 6px;">
            ${{ '{' }}{{ baseTable.table_name }}.{{ f.field_name }}{{ '}' }}
          </button>
          <button type="button" class="btn btn-sm w-100 text-start mb-1 token-btn search-token-btn d-none"
            data-token="$search[{{ baseTable.table_name }}.{{ f.field_name }}]"
            style="background:#dcfce7;color:#166534;border:none;font-family:monospace;font-size:0.75rem;padding:2px 6px 2px 16px;">
            $search[{{ baseTable.table_name }}.{{ f.field_name }}]
          </button>
          <button type="button" class="btn btn-sm w-100 text-start mb-1 token-btn update-token-btn d-none"
            data-token="$update[{{ baseTable.table_name }}.{{ f.field_name }}]"
            style="background:#dbeafe;color:#1e40af;border:none;font-family:monospace;font-size:0.75rem;padding:2px 6px 2px 16px;">
            $update[{{ baseTable.table_name }}.{{ f.field_name }}]
          </button>
          {% endfor %}
          {% endif %}

          {% if joinedFields.length %}
          <div class="text-muted small mt-2 mb-1" style="font-size:0.7rem;">JOINED TABLES</div>
          {% for f in joinedFields %}
          <button type="button" class="btn btn-sm w-100 text-start mb-1 token-btn"
            data-token="${{ '{' }}{{ f.table_name }}.{{ f.field_name }}{{ '}' }}"
            style="background:#f0fdf4;color:#166534;border:none;font-family:monospace;font-size:0.75rem;padding:2px 6px;">
            ${{ '{' }}{{ f.table_name }}.{{ f.field_name }}{{ '}' }}
          </button>
          <button type="button" class="btn btn-sm w-100 text-start mb-1 token-btn search-token-btn d-none"
            data-token="$search[{{ f.table_name }}.{{ f.field_name }}]"
            style="background:#dcfce7;color:#166534;border:none;font-family:monospace;font-size:0.75rem;padding:2px 6px 2px 16px;">
            $search[{{ f.table_name }}.{{ f.field_name }}]
          </button>
          <button type="button" class="btn btn-sm w-100 text-start mb-1 token-btn update-token-btn d-none"
            data-token="$update[{{ f.table_name }}.{{ f.field_name }}]"
            style="background:#dbeafe;color:#1e40af;border:none;font-family:monospace;font-size:0.75rem;padding:2px 6px 2px 16px;">
            $update[{{ f.table_name }}.{{ f.field_name }}]
          </button>
          {% endfor %}
          {% endif %}

          <div class="text-muted small mt-2 mb-1" style="font-size:0.7rem;">SYSTEM TOKENS</div>
          {% set sysTokens = [
            ['_pk',          'Primary key of this row'],
            ['_row_num',     'Row number in results'],
            ['_q',           'Current search term'],
            ['_page',        'Current page number'],
            ['_total',       'Total record count'],
            ['_total_pages', 'Total pages'],
            ['_has_prev',    'Non-empty if prev page exists'],
            ['_has_next',    'Non-empty if next page exists'],
            ['_prev_page',   'Previous page number'],
            ['_next_page',   'Next page number'],
            ['_pagination',  'Full pagination widget (HTML)'],
            ['_sort',        'Current sort field'],
            ['_dir',         'Current sort direction'],
            ['_group_value', 'Value of grouping field (group templates)']
          ] %}
          {% for tok in sysTokens %}
          <button type="button" class="btn btn-sm w-100 text-start mb-1 token-btn"
            data-token="${{ '{' }}{{ tok[0] }}{{ '}' }}"
            title="{{ tok[1] }}"
            style="background:#fff3cd;color:#664d03;border:none;font-family:monospace;font-size:0.75rem;padding:2px 6px;">
            ${{ '{' }}{{ tok[0] }}{{ '}' }}
          </button>
          {% endfor %}

          <div class="text-muted small mt-2 mb-1" style="font-size:0.7rem;">INTERACTION ATTRIBUTES</div>
          <div style="font-size:0.72rem;color:#6b7280;line-height:1.8;">
            <code>data-wdp-action="detail"</code><br>
            <code>data-wdp-id="\${_pk}"</code><br>
            <code>data-wdp-action="edit"</code><br>
            <code>data-wdp-action="back"</code><br>
            <code>data-wdp-action="page"</code><br>
            <code>data-wdp-page="\${_next_page}"</code><br>
            <code>data-wdp-action="sort"</code><br>
            <code>data-wdp-field="title"</code><br>
            <code>data-wdp-form="search"</code><br>
            <code>data-wdp-form="edit"</code><br>
            <code>$update[table.field]</code>
          </div>

          <div class="text-muted small mt-2 mb-1" style="font-size:0.7rem;">TEMPLATE TAGS</div>
          <div style="font-size:0.72rem;color:#6b7280;line-height:1.6;">
            <div class="mb-1"><strong style="color:#374151;">$if()</strong> — conditional output</div>
            <code style="font-size:0.7rem;word-break:break-all;">$if(field &gt; value, "true html", "false html")</code>
            <div class="text-muted mt-1 mb-2" style="font-size:0.68rem;">
              Operators: <code>&gt; &lt; &gt;= &lt;= == != &lt;&gt;</code><br>
              Wrap branch values in quotes if they contain commas.<br>
              Branches may contain <code>\${...}</code> tokens.
            </div>
            <div class="mb-1"><strong style="color:#374151;">&lt;group&gt;</strong> — multi-row concat</div>
            <code style="font-size:0.7rem;word-break:break-all;">&lt;group delimiter=", "&gt;\${authors.first_name} \${authors.last_name}&lt;/group&gt;</code>
            <div class="text-muted mt-1" style="font-size:0.68rem;">
              Groups joined rows into a single delimited value via SQL GROUP_CONCAT.
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  {# ── SQL section ── #}
  <div class="card shadow-sm mt-3">
    <div class="card-header d-flex align-items-center justify-content-between py-2" style="cursor:pointer;" id="sql-card-header">
      <span>
        <i class="bi bi-chevron-{{ 'down' if view.query_mode == 'advanced_sql' else 'right' }} me-1 text-muted" id="sql-chevron" style="font-size:0.8rem;transition:transform 0.15s;"></i>
        <i class="bi bi-terminal me-2"></i><strong>Query SQL</strong>
        <span id="sql-mode-badge" class="badge ms-2
          {{ 'bg-warning text-dark' if view.query_mode == 'advanced_sql' else 'bg-light text-dark border' }}">
          {{ 'Custom SQL' if view.query_mode == 'advanced_sql' else 'Auto-generated' }}
        </span>
      </span>
      <div class="d-flex gap-2" onclick="event.stopPropagation()">
        <button type="button" id="btn-refresh-sql" class="btn btn-sm btn-outline-secondary">
          <i class="bi bi-arrow-clockwise me-1"></i>Refresh SQL
        </button>
        <button type="button" id="btn-customize-sql" class="btn btn-sm btn-outline-warning"
          {% if view.query_mode == 'advanced_sql' %}style="display:none"{% endif %}>
          Customize SQL
        </button>
        <button type="button" id="btn-reset-sql" class="btn btn-sm btn-outline-secondary"
          {% if view.query_mode != 'advanced_sql' %}style="display:none"{% endif %}>
          Reset to Auto
        </button>
      </div>
    </div>
    <div id="sql-collapsible" {% if view.query_mode != 'advanced_sql' %}style="display:none"{% endif %}>
      <div class="card-body p-0">
        <textarea id="sql-editor" class="form-control font-monospace border-0 rounded-0"
          rows="8" style="font-size:0.8rem;resize:vertical;border-radius:0 !important;"
          {% if view.query_mode != 'advanced_sql' %}readonly{% endif %}>{{ view.custom_sql if view.query_mode == 'advanced_sql' else generatedSql }}</textarea>
      </div>
      <div class="card-footer py-2 text-muted small" id="sql-hint">
        {% if view.query_mode == 'advanced_sql' %}
        Custom SQL active. Column aliases become available as <code>\${alias}</code> tokens in templates.
        {% else %}
        Auto-generated from <code>\${table.field}</code> tokens found in your templates. Click <em>Customize SQL</em> to edit.
        {% endif %}
      </div>
    </div>
  </div>

  {# ── Save ── #}
  <div class="d-flex gap-2 mt-3 align-items-center">
    <button type="submit" class="btn btn-primary">
      <i class="bi bi-check-lg me-1"></i>Save All Templates
    </button>
    <a href="/admin/views/{{ view.id }}/edit" class="btn btn-outline-secondary">Settings</a>
    <span id="save-indicator" class="text-muted small ms-2" style="opacity:0;transition:opacity 0.4s;">Saved</span>
  </div>
</form>

{# ── AI Design modal ── #}
<div class="modal fade" id="aiModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-stars me-2"></i>AI Design</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <p class="text-muted small mb-3">
          AI will read your table schema and sample data, then write all 8 templates for you.
          Describe the style you want, or leave blank for a clean default.
        </p>
        <label class="form-label">Style description <span class="text-muted fw-normal">(optional)</span></label>
        <textarea id="ai-style-hint" class="form-control" rows="3"
          placeholder="e.g. racing results with times, positions, and owner names — bold headers, dark theme"></textarea>
        <div id="ai-status" class="mt-3 small text-muted" style="display:none;"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" id="btn-ai-go" class="btn btn-warning">
          <i class="bi bi-stars me-1"></i>Generate templates
        </button>
      </div>
    </div>
  </div>
</div>

{# ── Designer Reference Modal ─────────────────────────────────────────────── #}
<div class="modal fade" id="designerRefModal" tabindex="-1" aria-labelledby="designerRefModalLabel">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content">

      <div class="modal-header py-2">
        <h5 class="modal-title" id="designerRefModalLabel">
          <i class="bi bi-book me-2"></i>Webdata Pro — Designer Reference
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body p-0" style="display:flex;min-height:70vh;">

        {# ── Left nav ── #}
        <nav class="d-none d-md-block" style="width:200px;min-width:200px;border-right:1px solid #e2e8f0;padding:16px 0;background:#f8fafc;">
          {% set refSections = [
            ['ref-overview',    'bi-grid-3x3-gap', 'Template Slots'],
            ['ref-tokens',      'bi-braces',        'Tokens & Expressions'],
            ['ref-search',      'bi-search',        'Search Form'],
            ['ref-actions',     'bi-cursor-fill',   'Actions & Forms'],
            ['ref-sql',         'bi-terminal',      'SQL & Calculations'],
            ['ref-how',         'bi-diagram-3',     'How It Works'],
            ['ref-embed',       'bi-code-slash',    'Embedding']
          ] %}
          {% for sec in refSections %}
          <a href="#{{ sec[0] }}" class="ref-nav-link d-flex align-items-center gap-2 px-4 py-2 text-decoration-none"
            style="font-size:0.82rem;color:#475569;border-left:3px solid transparent;">
            <i class="bi {{ sec[1] }}"></i>{{ sec[2] }}
          </a>
          {% endfor %}
        </nav>

        {# ── Content ── #}
        <div class="ref-content flex-fill p-4" style="overflow-y:auto;max-height:72vh;font-size:0.88rem;line-height:1.65;">

          {# ── TEMPLATE SLOTS ── #}
          <section id="ref-overview" class="ref-section mb-5">
            <h4 class="ref-h4">Template Slots</h4>
            <p class="text-muted">Each view has eight template slots. They render in sequence to build the complete widget output. All slots share the same token syntax.</p>
            <table class="table table-sm table-bordered" style="font-size:0.82rem;">
              <thead class="table-light"><tr><th>Slot</th><th>When it renders</th><th>Typical use</th></tr></thead>
              <tbody>
                <tr><td><code>search_form</code></td><td>Once, at the top — always visible</td><td>Search inputs, filter controls</td></tr>
                <tr><td><code>header</code></td><td>Once, between search form and first row</td><td>Column headings, record count, sort buttons</td></tr>
                <tr><td><code>group_header</code></td><td>Once per group (when grouping is set)</td><td>Group label/divider</td></tr>
                <tr><td><code>row</code></td><td>Once per record</td><td>Title, summary, thumbnail, action buttons</td></tr>
                <tr><td><code>group_footer</code></td><td>Once after the last row of each group</td><td>Group subtotals, closing dividers</td></tr>
                <tr><td><code>footer</code></td><td>Once, after all rows</td><td>Pagination</td></tr>
                <tr><td><code>detail</code></td><td>When a row is clicked</td><td>Full record layout, edit button</td></tr>
                <tr><td><code>edit_form</code></td><td>When the Edit button is clicked</td><td>Input form for updating a record</td></tr>
              </tbody>
            </table>
            <div class="alert alert-info py-2" style="font-size:0.82rem;">
              <strong>How modes work:</strong> The widget lives in one DOM element. Clicking a row replaces the list with the detail view inside that same element. Clicking Back restores the list from cache. No page navigation happens — it's all in-place.
            </div>
          </section>

          {# ── TOKENS & EXPRESSIONS ── #}
          <section id="ref-tokens" class="ref-section mb-5">
            <h4 class="ref-h4">Tokens &amp; Expressions</h4>

            <h6 class="ref-h6">Field values — <code>${'$'}{table.field}</code></h6>
            <p>Every column in your query is available as a token. For auto-generated queries use <code>${'$'}{tablename.fieldname}</code>. For custom SQL, use whatever alias you gave the column.</p>
            <pre class="ref-pre">${'$'}{pets.name}          — a field from the base table
${'$'}{owners.last_name}   — a field from a joined table
${'$'}{age_in_years}       — a custom SQL alias</pre>

            <h6 class="ref-h6 mt-3">System tokens</h6>
            <pre class="ref-pre">${'$'}{_pk}            Primary key of the current row
${'$'}{_row_num}       Row number starting at 1
${'$'}{_q}            Current search term (empty if none)
${'$'}{_page}         Current page number
${'$'}{_total}        Total records matching the current search
${'$'}{_total_pages}  Total pages
${'$'}{_has_prev}     Non-empty string if a previous page exists
${'$'}{_has_next}     Non-empty string if a next page exists
${'$'}{_prev_page}    Previous page number
${'$'}{_next_page}    Next page number
${'$'}{_pagination}   Ready-made Prev / Page X of Y / Next widget
${'$'}{_sort}         Current sort field name
${'$'}{_dir}          Current sort direction: "asc" or "desc"
${'$'}{_group_value}  Value of the grouping field (group templates only)</pre>

            <h6 class="ref-h6 mt-3">Metadata tokens (detail &amp; edit_form)</h6>
            <pre class="ref-pre">${'$'}{_meta.created_by}   Member who first saved the record
${'$'}{_meta.created_at}   When it was first saved
${'$'}{_meta.updated_by}   Last member to edit it
${'$'}{_meta.updated_at}   When it was last edited</pre>

            <h6 class="ref-h6 mt-3">JavaScript ternary — inline logic</h6>
            <p>Any token expression can be a full JavaScript ternary because tokens are evaluated inside template literals:</p>
            <pre class="ref-pre">${'$'}{pets.age_months &lt; 24 ? '🐾 Puppy' : pets.age_months &gt; 96 ? '🦮 Senior' : 'Mid range'}

${'$'}{_sort == 'name' ? (_dir == 'asc' ? '▲' : '▼') : ''}</pre>

            <h6 class="ref-h6 mt-3">$if() — conditional blocks</h6>
            <p>For longer conditional HTML, <code>$if()</code> is cleaner than a ternary:</p>
            <pre class="ref-pre">$if(pets.good_for_kids, "&lt;span class='badge bg-success'&gt;Kid friendly&lt;/span&gt;")
$if(pets.age_months &gt; 96, "&lt;em&gt;Senior&lt;/em&gt;", "&lt;em&gt;Young&lt;/em&gt;")</pre>
            <p class="text-muted small">Operators: <code>&gt; &lt; &gt;= &lt;= == != &lt;&gt;</code>. Wrap branch text in quotes if it contains a comma. Both branches may contain <code>${'$'}{...}</code> tokens.</p>

            <h6 class="ref-h6 mt-3">&lt;group&gt; — multi-row concat</h6>
            <p>When a JOIN produces multiple rows per record (e.g. one book with many authors), wrap the repeating content so the system uses SQL <code>GROUP_CONCAT</code> to collapse them:</p>
            <pre class="ref-pre">&lt;group delimiter=", "&gt;${'$'}{authors.first_name} ${'$'}{authors.last_name}&lt;/group&gt;</pre>
          </section>

          {# ── SEARCH FORM ── #}
          <section id="ref-search" class="ref-section mb-5">
            <h4 class="ref-h4">Search Form</h4>

            <h6 class="ref-h6">Required form attribute</h6>
            <p>The widget identifies your search form by the attribute <code>data-wdp-form="search"</code> on the <code>&lt;form&gt;</code> tag. Without it nothing is submitted.</p>
            <pre class="ref-pre">&lt;form data-wdp-form="search"&gt;
  ...
&lt;/form&gt;</pre>

            <h6 class="ref-h6 mt-3">Global keyword search — <code>name="q"</code></h6>
            <p>A single text input that runs a <code>LIKE %value%</code> search across every text column in the query simultaneously.</p>
            <pre class="ref-pre">&lt;input type="text" name="q" value="${'$'}{_q}" placeholder="Search…"&gt;</pre>
            <p class="text-muted small"><code>${'$'}{_q}</code> pre-fills the box so users can refine their search without retyping.</p>

            <h6 class="ref-h6 mt-3">Per-field inputs — <code>name="table__field"</code></h6>
            <p>Any input whose name matches the pattern <code>tablename__fieldname</code> (two underscores) is applied as a filter on that specific column. You can write this HTML by hand — no tokens required:</p>
            <pre class="ref-pre">&lt;input type="text" name="pets__name" placeholder="Name…"&gt;
&lt;input type="text" name="pets__breed" placeholder="Breed…"&gt;</pre>

            <h6 class="ref-h6 mt-3">Auto-rendered inputs — <code>$search[table.field]</code></h6>
            <p>Generates the right input for the field's widget type automatically (text box, select, Yes/No/Any for checkboxes). Useful for building a search panel quickly without writing HTML.</p>
            <pre class="ref-pre">$search[pets.name]
$search[pets.animal_type]
$search[pets.good_for_kids]</pre>

            <h6 class="ref-h6 mt-3">Filter operators — value prefixes</h6>
            <p>By default, filters use <code>LIKE %value%</code> — good for text. For numbers, dates, and ranges, prefix the value with an operator. This works on any input the designer controls, including hidden fields and selects:</p>
            <table class="table table-sm table-bordered" style="font-size:0.82rem;">
              <thead class="table-light"><tr><th>Value</th><th>SQL generated</th><th>Example use</th></tr></thead>
              <tbody>
                <tr><td><code>poodle</code></td><td><code>LIKE '%poodle%'</code></td><td>Default text search</td></tr>
                <tr><td><code>=1</code></td><td><code>= '1'</code></td><td>Exact match (checkbox true/false)</td></tr>
                <tr><td><code>&gt;48</code></td><td><code>&gt; '48'</code></td><td>Older than 4 years (age_months)</td></tr>
                <tr><td><code>&lt;24</code></td><td><code>&lt; '24'</code></td><td>Under 2 years old</td></tr>
                <tr><td><code>24..96</code></td><td><code>&gt;= '24' AND &lt;= '96'</code></td><td>Age range</td></tr>
                <tr><td><code>&gt;=2020-01-01</code></td><td><code>&gt;= '2020-01-01'</code></td><td>Born after a date</td></tr>
              </tbody>
            </table>

            <h6 class="ref-h6 mt-3">Custom select with JavaScript date calculation</h6>
            <p>For fields like <code>dob</code> where the meaningful search is "Puppy / Mid Range / Senior" rather than a raw date, use a hidden field plus a JavaScript function. The function calculates today's actual date boundary at query time — so the age categories stay accurate forever.</p>
            <pre class="ref-pre">&lt;input type="hidden" name="pets__dob" id="dob_filter"&gt;
&lt;select onchange="setDobFilter(this.value)"&gt;
  &lt;option value=""&gt;Any age&lt;/option&gt;
  &lt;option value="puppy"&gt;Puppy (under 2 yrs)&lt;/option&gt;
  &lt;option value="mid"&gt;Mid Range (2–8 yrs)&lt;/option&gt;
  &lt;option value="senior"&gt;Senior (8+ yrs)&lt;/option&gt;
&lt;/select&gt;

&lt;script&gt;
function setDobFilter(val) {
  var field = document.getElementById('dob_filter');
  var now = new Date();
  function ago(yrs) {
    return new Date(now.getFullYear()-yrs, now.getMonth(), now.getDate())
      .toISOString().slice(0,10);
  }
  if (val === 'puppy')  field.value = '&gt;' + ago(2);
  if (val === 'mid')    field.value = ago(8) + '..' + ago(2);
  if (val === 'senior') field.value = '&lt;' + ago(8);
  if (!val)             field.value = '';
}
&lt;/script&gt;</pre>
            <p class="text-muted small"><strong>Note:</strong> <code>&lt;script&gt;</code> tags in templates are executed correctly — the widget re-runs them after each render.</p>

            <h6 class="ref-h6 mt-3">Simple / Advanced toggle panel</h6>
            <p>The widget auto-injects an Advanced panel for templates that don't already have one. To take full control, add your own <code>.wdp-sf-simple</code> and <code>.wdp-sf-adv</code> divs inside the form — the auto-injection is skipped when these are present.</p>
            <pre class="ref-pre">&lt;form data-wdp-form="search"&gt;
  &lt;div class="wdp-sf-simple"&gt;
    &lt;input type="text" name="q" value="${'$'}{_q}" placeholder="Search…"&gt;
    &lt;button type="submit"&gt;Search&lt;/button&gt;
    &lt;a href="#" onclick="…show adv…"&gt;Advanced&lt;/a&gt;
  &lt;/div&gt;
  &lt;div class="wdp-sf-adv" style="display:none"&gt;
    &lt;!-- your custom advanced fields --&gt;
    &lt;button type="submit"&gt;Search&lt;/button&gt;
    &lt;button type="button" onclick="…show simple…"&gt;↑ Simple&lt;/button&gt;
  &lt;/div&gt;
&lt;/form&gt;</pre>
          </section>

          {# ── ACTIONS & FORMS ── #}
          <section id="ref-actions" class="ref-section mb-5">
            <h4 class="ref-h4">Actions &amp; Forms</h4>
            <p>Any element can be made interactive by adding <code>data-wdp-action</code> attributes. The widget listens for clicks and form submits via event delegation — no per-element JavaScript needed.</p>

            <table class="table table-sm table-bordered" style="font-size:0.82rem;">
              <thead class="table-light"><tr><th>Attribute</th><th>Goes on</th><th>What it does</th></tr></thead>
              <tbody>
                <tr><td><code>data-wdp-action="detail"</code> + <code>data-wdp-id="${'$'}{_pk}"</code></td><td>Any element in a row</td><td>Loads the detail view for that record</td></tr>
                <tr><td><code>data-wdp-action="edit"</code> + <code>data-wdp-id="${'$'}{_pk}"</code></td><td>Any element</td><td>Loads the edit form for that record</td></tr>
                <tr><td><code>data-wdp-action="back"</code></td><td>Any element</td><td>Returns to the list view</td></tr>
                <tr><td><code>data-wdp-action="page"</code> + <code>data-wdp-page="${'$'}{_next_page}"</code></td><td>Any element</td><td>Navigates to a specific page</td></tr>
                <tr><td><code>data-wdp-action="sort"</code> + <code>data-wdp-field="fieldname"</code></td><td>Any element</td><td>Sorts by the field; repeated clicks toggle asc/desc</td></tr>
                <tr><td><code>data-wdp-action="clear"</code></td><td>Any element</td><td>Clears all search filters and reloads</td></tr>
                <tr><td><code>data-wdp-form="search"</code></td><td><code>&lt;form&gt;</code></td><td>Marks the search form — submit is intercepted</td></tr>
                <tr><td><code>data-wdp-form="edit"</code> + <code>data-wdp-id</code></td><td><code>&lt;form&gt;</code></td><td>Marks the edit form — submit sends a PATCH request</td></tr>
              </tbody>
            </table>

            <h6 class="ref-h6 mt-3">$update[table.field] — auto-rendered edit inputs</h6>
            <p>In the <code>edit_form</code> template, use this token to generate the correct input widget pre-filled with the current value. The <code>name</code> attribute is set automatically.</p>
            <pre class="ref-pre">$update[pets.name]           → &lt;input type="text" name="pets__name" value="Penny"&gt;
$update[pets.animal_type]    → &lt;select name="pets__animal_type"&gt;…&lt;/select&gt;
$update[pets.good_for_kids]  → &lt;input type="checkbox" name="pets__good_for_kids"&gt;</pre>
          </section>

          {# ── SQL & CALCULATIONS ── #}
          <section id="ref-sql" class="ref-section mb-5">
            <h4 class="ref-h4">SQL &amp; Calculations</h4>

            <h6 class="ref-h6">Auto-generated SQL</h6>
            <p>By default, the query is built automatically from the <code>${'$'}{table.field}</code> tokens in your templates. You never have to write SQL unless you need something the auto-builder can't express.</p>

            <h6 class="ref-h6 mt-3">Custom SQL — calculated columns</h6>
            <p>Click <strong>Customize SQL</strong> in the SQL panel to take full control. You can add calculated columns using standard SQLite expressions. Any column alias you define becomes available as a <code>${'$'}{alias}</code> token:</p>
            <pre class="ref-pre">SELECT
  pets.*,
  -- Age calculated fresh on every query
  ROUND((julianday('now') - julianday(pets.dob)) / 365.25, 1) AS age_years,
  -- Friendly age tier
  CASE
    WHEN (julianday('now') - julianday(pets.dob)) / 365.25 &lt; 2  THEN 'Puppy'
    WHEN (julianday('now') - julianday(pets.dob)) / 365.25 &lt; 8  THEN 'Mid Range'
    ELSE 'Senior'
  END AS age_tier
FROM pets</pre>
            <p>Then in your row template:</p>
            <pre class="ref-pre">${'$'}{pets.name} — ${'$'}{age_tier} (${'$'}{age_years} yrs)</pre>

            <h6 class="ref-h6 mt-3">Calculations in template JavaScript</h6>
            <p>For display-only formatting, you can calculate directly in the template using JavaScript expressions. The server sends raw values; the browser computes the display:</p>
            <pre class="ref-pre">&lt;!-- Age from DOB, calculated in the browser --&gt;
${'$'}{Math.floor((Date.now() - new Date(pets.dob)) / (365.25*24*60*60*1000))} yrs old

&lt;!-- Price formatted as currency --&gt;
${'$'}{Number(items.price).toFixed(2)}

&lt;!-- Conditional badge --&gt;
${'$'}{pets.age_months &lt; 24 ? '🐾 Puppy' : pets.age_months &gt; 96 ? '🦮 Senior' : 'Adult'}</pre>
            <div class="alert alert-warning py-2 mt-2" style="font-size:0.82rem;">
              <strong>SQL vs template JS — which to use:</strong> Use SQL when you need to <em>filter or sort</em> by the calculated value. Use template JS when you only need to <em>display</em> it differently. You can't filter by a value that only exists in the browser.
            </div>
          </section>

          {# ── HOW IT WORKS ── #}
          <section id="ref-how" class="ref-section mb-5">
            <h4 class="ref-h4">How It Works</h4>
            <p>Understanding the flow lets you build custom search controls, style the loading state, and debug unexpected behaviour.</p>

            <h6 class="ref-h6">The render cycle</h6>
            <ol style="line-height:2;">
              <li>User action triggers a state change (search submit, page click, etc.)</li>
              <li>embed.js encodes the new state into the URL hash: <code>#wdp-myview=mode:list|page:2|q:poodle</code></li>
              <li>embed.js fetches the appropriate API endpoint (see below)</li>
              <li>The server runs the SQL, renders all templates, and returns HTML</li>
              <li>embed.js sets <code>el.innerHTML</code> with the new HTML — the widget div is replaced in place</li>
              <li>Any <code>&lt;script&gt;</code> tags in the returned HTML are re-executed</li>
            </ol>

            <h6 class="ref-h6 mt-3">API endpoints called by embed.js</h6>
            <table class="table table-sm table-bordered" style="font-size:0.82rem;">
              <thead class="table-light"><tr><th>Mode</th><th>Endpoint</th><th>Parameters</th></tr></thead>
              <tbody>
                <tr><td>List</td><td><code>GET /api/:app/views/:view/render</code></td><td><code>q, page, sort, dir, f_table__field, …</code></td></tr>
                <tr><td>Detail</td><td><code>GET /api/:app/views/:view/render/:id</code></td><td>Record ID in path</td></tr>
                <tr><td>Edit form</td><td><code>GET /api/:app/views/:view/render/:id/edit</code></td><td>Record ID in path</td></tr>
                <tr><td>Create form</td><td><code>GET /api/:app/views/:view/render/create</code></td><td>—</td></tr>
                <tr><td>Save edit</td><td><code>PATCH /api/:app/views/:view/records/:id</code></td><td>Form fields in body</td></tr>
              </tbody>
            </table>
            <p class="text-muted small">Replace <code>:app</code> with the app slug and <code>:view</code> with the view name.</p>

            <h6 class="ref-h6 mt-3">URL hash state</h6>
            <p>Each widget instance stores its state in the URL hash. Multiple widgets on the same page don't interfere — each uses a key derived from its element ID:</p>
            <pre class="ref-pre">#wdp-pets=mode:list|page:1|q:poodle|f_pets__animal_type:Dog</pre>
            <p>The <code>f_</code> prefix marks per-field filter values. This means bookmarking or sharing a URL preserves the current search state.</p>

            <h6 class="ref-h6 mt-3">The widget DOM element</h6>
            <p>The widget lives entirely inside the element you mounted it on. On every render, only that element's <code>innerHTML</code> is replaced — nothing outside it is touched. This makes it safe to embed alongside other React components, WordPress blocks, or existing page content.</p>
            <pre class="ref-pre">&lt;div id="my-widget"&gt;
  &lt;!-- Everything here is owned by Webdata Pro --&gt;
  &lt;!-- Replaced on every render               --&gt;
&lt;/div&gt;</pre>

            <h6 class="ref-h6 mt-3">Authentication</h6>
            <p>Public views require no credentials. For member-protected views, embed.js handles a JWT challenge automatically — it redirects to the login page, then returns the user to the current view after authentication. The token is stored in memory (never in localStorage) for the lifetime of the page.</p>
          </section>

          {# ── EMBEDDING ── #}
          <section id="ref-embed" class="ref-section mb-5">
            <h4 class="ref-h4">Embedding</h4>

            <h6 class="ref-h6">Vanilla HTML / any CMS</h6>
            <pre class="ref-pre">&lt;!-- Load once per page --&gt;
&lt;script src="https://yourserver.com/static/embed.js"&gt;&lt;/script&gt;

&lt;!-- Place this where you want the widget --&gt;
&lt;div id="wdp-{{ view.view_name }}"&gt;&lt;/div&gt;
&lt;script&gt;
  WDP.mount('#wdp-{{ view.view_name }}', {
    app:     '{{ currentApp.slug }}',
    view:    '{{ view.view_name }}',
    baseUrl: 'https://yourserver.com'
  });
&lt;/script&gt;</pre>

            <h6 class="ref-h6 mt-3">React component wrapper</h6>
            <pre class="ref-pre">import { useEffect, useRef } from 'react';

function WDPWidget({ app, view, baseUrl }) {
  const ref = useRef(null);

  useEffect(() => {
    // Load embed.js once
    if (!window.WDP) {
      const s = document.createElement('script');
      s.src = baseUrl + '/static/embed.js';
      s.onload = () => window.WDP.mount(ref.current, { app, view, baseUrl });
      document.head.appendChild(s);
    } else {
      window.WDP.mount(ref.current, { app, view, baseUrl });
    }
    // WDP owns the innerHTML — React should not diff it
    return () => { if (ref.current) ref.current.innerHTML = ''; };
  }, [app, view, baseUrl]);

  return &lt;div ref={ref} /&gt;;
}

// Usage
&lt;WDPWidget app="pet-shelter" view="pets_browse"
           baseUrl="https://yourserver.com" /&gt;</pre>
            <div class="alert alert-info py-2" style="font-size:0.82rem;">
              The <code>return () =&gt; innerHTML = ''</code> cleanup prevents React from trying to reconcile DOM that Webdata Pro owns. Without it you may see React warnings on hot-reload.
            </div>

            <h6 class="ref-h6 mt-3">WordPress</h6>
            <p>Add this to your theme's <code>functions.php</code> or a custom plugin:</p>
            <pre class="ref-pre">// Register shortcode: [wdp_view app="pet-shelter" view="pets_browse"]
add_shortcode('wdp_view', function($atts) {
  $a = shortcode_atts(['app'=>'','view'=>'','base_url'=>'https://yourserver.com'], $atts);
  $id = 'wdp-' . esc_attr($a['view']);
  return sprintf(
    '&lt;div id="%s"&gt;&lt;/div&gt;
     &lt;script src="%s/static/embed.js"&gt;&lt;/script&gt;
     &lt;script&gt;WDP.mount("#%s",{app:"%s",view:"%s",baseUrl:"%s"});&lt;/script&gt;',
    $id, esc_url($a['base_url']), $id,
    esc_js($a['app']), esc_js($a['view']), esc_url($a['base_url'])
  );
});</pre>
            <p>Then in any post or page: <code>[wdp_view app="pet-shelter" view="pets_browse"]</code></p>

            <h6 class="ref-h6 mt-3">CORS</h6>
            <p>Cross-origin requests are allowed per-app. If you embed this widget on a different domain or port than this server, go to <a href="/admin/app-settings" target="_blank">App Settings</a> and add that origin (e.g. <code>https://localshelter.com</code>) to the <strong>Allowed Origins</strong> list. Use <code>*</code> to allow any origin (suitable for fully public, read-only views).</p>

            <h6 class="ref-h6 mt-3">WDP.mount() options</h6>
            <table class="table table-sm table-bordered" style="font-size:0.82rem;">
              <thead class="table-light"><tr><th>Option</th><th>Type</th><th>Description</th></tr></thead>
              <tbody>
                <tr><td><code>app</code></td><td>string</td><td>App slug (required)</td></tr>
                <tr><td><code>view</code></td><td>string</td><td>View name (required)</td></tr>
                <tr><td><code>baseUrl</code></td><td>string</td><td>Server URL, empty string for same-origin</td></tr>
                <tr><td><code>requireSearch</code></td><td>boolean</td><td>Don't load results until the user searches</td></tr>
                <tr><td><code>pageSize</code></td><td>number</td><td>Override the view's default page size</td></tr>
                <tr><td><code>token</code></td><td>string</td><td>Pre-supply a JWT for member authentication</td></tr>
              </tbody>
            </table>
          </section>

        </div>{# end ref-content #}
      </div>{# end modal-body #}

      <div class="modal-footer py-2 d-flex justify-content-between align-items-center">
        <a href="/admin/styleguide" target="_blank" class="btn btn-sm btn-outline-secondary">
          <i class="bi bi-palette me-1"></i>CSS Style Guide
        </a>
        <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

<style>
.ref-h4 { font-size:1rem; font-weight:700; color:#1e293b; border-bottom:2px solid #e2e8f0; padding-bottom:6px; margin-bottom:14px; }
.ref-h6 { font-size:0.82rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; color:#475569; margin-bottom:6px; }
.ref-pre { background:#f1f5f9; border:1px solid #e2e8f0; border-radius:5px; padding:10px 14px; font-size:0.78rem; white-space:pre-wrap; word-break:break-all; color:#1e293b; margin-bottom:10px; }
.ref-nav-link:hover, .ref-nav-link.active { background:#e2e8f0; color:#0f172a !important; border-left-color:#3b82f6 !important; }
.ref-section { scroll-margin-top: 16px; }
</style>

<script>
// ── Ref modal nav highlighting ────────────────────────────────────────────────
(function() {
  var modal = document.getElementById('designerRefModal');
  if (!modal) return;
  modal.addEventListener('shown.bs.modal', function() {
    var content  = modal.querySelector('.ref-content');
    var navLinks = modal.querySelectorAll('.ref-nav-link');
    if (!content || !navLinks.length) return;
    function updateActive() {
      var sections = modal.querySelectorAll('.ref-section');
      var active = sections[0];
      sections.forEach(function(s) {
        if (s.getBoundingClientRect().top <= content.getBoundingClientRect().top + 40) active = s;
      });
      navLinks.forEach(function(a) {
        var isActive = a.getAttribute('href') === '#' + active.id;
        a.classList.toggle('active', isActive);
        a.style.borderLeftColor = isActive ? '#3b82f6' : 'transparent';
      });
    }
    content.addEventListener('scroll', updateActive);
    navLinks.forEach(function(a) {
      a.addEventListener('click', function(e) {
        e.preventDefault();
        var target = modal.querySelector(a.getAttribute('href'));
        if (target) target.scrollIntoView({ behavior: 'smooth' });
      });
    });
    updateActive();
  });
}());
</script>

<script>
(function () {
  // ── Template tab switching ────────────────────────────────────────────────
  const panels   = document.querySelectorAll('.tpl-panel');
  const buttons  = document.querySelectorAll('#tpl-selector button[data-tpl]');

  function applyTabState(tpl) {
    const isEdit   = tpl === 'edit_form';
    const isSearch = tpl === 'search_form';
    document.querySelectorAll('.update-token-btn').forEach(b => b.classList.toggle('d-none', !isEdit));
    document.querySelectorAll('.search-token-btn').forEach(b => b.classList.toggle('d-none', !isSearch));
    const updateHint = document.getElementById('update-hint');
    if (updateHint) updateHint.classList.toggle('d-none', !isEdit);
    const searchHint = document.getElementById('search-hint');
    if (searchHint) searchHint.classList.toggle('d-none', !isSearch);
  }

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      buttons.forEach(b => b.classList.remove('active'));
      panels.forEach(p => p.classList.add('d-none'));
      btn.classList.add('active');
      document.querySelector(`.tpl-panel[data-tpl="${btn.dataset.tpl}"]`)?.classList.remove('d-none');
      applyTabState(btn.dataset.tpl);
      updateHelp(btn.dataset.tpl);
    });
  });

  // Apply initial tab state for whichever tab is active on page load
  const activeBtn = document.querySelector('#tpl-selector button[data-tpl].active');
  if (activeBtn) applyTabState(activeBtn.dataset.tpl);

  // ── Inline help panel ─────────────────────────────────────────────────────

  const HS = 'padding:10px 14px;';   // section padding shorthand
  const H  = s => `<div style="font-size:0.72rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:#475569;margin:10px 0 4px;">${s}</div>`;
  const P  = s => `<p style="margin:0 0 7px;color:#374151;">${s}</p>`;
  const EX = s => `<pre style="margin:0 0 7px;background:#e2e8f0;border-radius:3px;padding:5px 8px;font-size:0.72rem;white-space:pre-wrap;word-break:break-all;color:#1e293b;">${s}</pre>`;
  const N  = s => `<p style="margin:0 0 7px;color:#64748b;font-style:italic;font-size:0.74rem;">${s}</p>`;

  const COMMON = `
    ${H('$if() — Conditional output')}
    ${P('Show different content based on a field value. Operators: <code>&gt; &lt; &gt;= &lt;= == != &lt;&gt;</code>. Wrap branch text in quotes if it contains a comma.')}
    ${EX('$if(books.price &gt; 30, "&lt;b&gt;Free shipping!&lt;/b&gt;", "Standard shipping")\n$if(books.featured, "&lt;span class=\\"badge\\"&gt;Featured&lt;/span&gt;")')}
    ${N('The true/false branches can contain ${...} tokens too.')}

    ${H('<group> — Multi-row concat')}
    ${P('When a book has multiple authors, a plain join produces one row per author. Wrap the repeating content in a <code>&lt;group&gt;</code> tag so the system rolls them up into one value using SQL <code>GROUP_CONCAT</code>.')}
    ${EX('&lt;group delimiter=", "&gt;\${authors.first_name} \${authors.last_name}&lt;/group&gt;')}
    ${N('The delimiter appears between each concatenated value. Any text or tokens inside the tag become part of each item.')}
  `;

  const HELP = {
    search_form: `<div style="${HS}">
      ${P('<em>This template renders once at the very top of the view. It stays visible while the user browses results below it.</em>')}

      ${H('data-wdp-form="search" (required)')}
      ${P('Put this attribute on your <code>&lt;form&gt;</code> tag. Without it the submit button does nothing — the widget won\'t know it\'s a search form.')}
      ${EX('&lt;form data-wdp-form="search"&gt; ... &lt;/form&gt;')}

      ${H('name="q" — Global keyword search')}
      ${P('A single text input that runs a <code>LIKE</code> search across <em>every</em> text column in your query at once.')}
      ${EX('&lt;input type="text" name="q" value="\${_q}" placeholder="Search..."&gt;')}
      ${N('\${_q} pre-fills the box when the user navigates back to the list.')}

      ${H('$search[table.field] — Per-field search')}
      ${P('Generates a search input whose type matches the field\'s widget setting — text box, date picker, dropdown, or a Yes/No/Any selector for checkboxes. The input is always blank on load.')}
      ${EX('$search[books.title]\n$search[books.type]\n$search[authors.last_name]')}
      ${N('You can mix name="q" and $search[...] fields in the same form — they combine with AND.')}

      ${H('data-wdp-action="clear"')}
      ${P('Resets all search fields and reloads the full result set. Put it on any clickable element.')}
      ${EX('&lt;a data-wdp-action="clear"&gt;✕ Clear&lt;/a&gt;')}

      ${H('Available tokens')}
      ${EX('\${_q}          Current search term\n\${_total}      Number of matching records')}
      ${COMMON}
    </div>`,

    header: `<div style="${HS}">
      ${P('<em>Renders once between the search form and the first result row. Use it for column headings, record counts, and sort controls.</em>')}

      ${H('Record count & search state')}
      ${EX('\${_total}        Total records found\n\${_q}           Current search term (empty if none)\n\${_page}        Current page number\n\${_total_pages} Total number of pages')}

      ${H('Sort buttons')}
      ${P('Add <code>data-wdp-action="sort"</code> and <code>data-wdp-field="fieldname"</code> to any clickable element to make a sortable column header. The widget toggles asc/desc on repeated clicks.')}
      ${EX('&lt;span data-wdp-action="sort" data-wdp-field="title" style="cursor:pointer;"&gt;\n  Title \${_sort == "title" ? (_dir == "asc" ? "▲" : "▼") : ""}\n&lt;/span&gt;')}
      ${N('Use just the field name (no table prefix) in data-wdp-field.')}
      ${COMMON}
    </div>`,

    group_header: `<div style="${HS}">
      ${P('<em>Renders once each time the grouping field\'s value changes — like a section divider between groups of rows. Requires a grouping field to be set in the view\'s Settings.</em>')}

      ${H('Key token')}
      ${EX('\${_group_value}   The value of the grouping field for this group')}
      ${P('All standard row tokens are also available here (see Row help).')}

      ${H('Typical use')}
      ${EX('&lt;div class="group-header"&gt;\${_group_value}&lt;/div&gt;')}
      ${COMMON}
    </div>`,

    row: `<div style="${HS}">
      ${P('<em>Renders once per record. This is where you lay out each result — title, author, description, thumbnail, etc.</em>')}

      ${H('Field values')}
      ${EX('\${books.title}          A field value (table.field)\n\${_pk}                 The primary key of this row\n\${_row_num}            Row number, starting at 1')}

      ${H('Clickable row → detail view')}
      ${P('Add these two attributes to any element (a div, tr, li…) to make it open the detail view when clicked.')}
      ${EX('&lt;div data-wdp-action="detail" data-wdp-id="\${_pk}"&gt;\n  \${books.title}\n&lt;/div&gt;')}

      ${H('Sort controls (often in Header, but can go here too)')}
      ${EX('&lt;span data-wdp-action="sort" data-wdp-field="title"&gt;Title&lt;/span&gt;')}

      ${COMMON}
    </div>`,

    group_footer: `<div style="${HS}">
      ${P('<em>Renders once after the last row of each group closes. Use it for group subtotals, dividers, or spacing. Often left blank.</em>')}

      ${H('Available tokens')}
      ${EX('\${_group_value}   The value of the group that just ended')}
      ${P('All standard row tokens (last row\'s values) are available here too.')}
      ${COMMON}
    </div>`,

    footer: `<div style="${HS}">
      ${P('<em>Renders once after all rows. The natural home for pagination controls.</em>')}

      ${H('Built-in pagination widget')}
      ${P('Drop this token in and you\'re done — it renders Prev / Page X of Y / Next buttons automatically.')}
      ${EX('\${_pagination}')}

      ${H('Manual pagination (build your own buttons)')}
      ${EX('\${_page}          Current page\n\${_total_pages}  Total pages\n\${_has_prev}     Non-empty string if a previous page exists\n\${_has_next}     Non-empty string if a next page exists\n\${_prev_page}    Previous page number\n\${_next_page}    Next page number')}
      ${EX('&lt;button data-wdp-action="page" data-wdp-page="\${_prev_page}"\n  \${_has_prev ? "" : "disabled"}&gt;← Prev&lt;/button&gt;\n&lt;button data-wdp-action="page" data-wdp-page="\${_next_page}"\n  \${_has_next ? "" : "disabled"}&gt;Next →&lt;/button&gt;')}
      ${COMMON}
    </div>`,

    detail: `<div style="${HS}">
      ${P('<em>Shown when the user clicks a row. Replaces the list view inside the widget. All field values for that single record are available.</em>')}

      ${H('Back button (required for navigation)')}
      ${EX('&lt;button data-wdp-action="back"&gt;← Back&lt;/button&gt;')}

      ${H('Edit button (shows to authorized members)')}
      ${EX('&lt;button data-wdp-action="edit" data-wdp-id="\${_pk}"&gt;Edit&lt;/button&gt;')}

      ${H('Field values')}
      ${EX('\${books.title}\n\${books.long_description}\n\${_pk}    Primary key')}
      ${N('Every column returned by your query is available here as \${table.field} or \${alias}.')}

      ${H('Record ownership tokens')}
      ${P('Available once a member has saved the record via an edit form.')}
      ${EX('\${_meta.created_by}   Name of the member who first saved this record\n\${_meta.created_at}   When it was first saved\n\${_meta.updated_by}   Name of the last member to edit it\n\${_meta.updated_at}   When it was last edited')}
      ${COMMON}
    </div>`,

    edit_form: `<div style="${HS}">
      ${P('<em>Shown to authorized members when they click Edit on a detail view. The form is pre-filled with the current record\'s values.</em>')}

      ${H('data-wdp-form="edit" + data-wdp-id (required)')}
      ${P('Both attributes are required on the <code>&lt;form&gt;</code> tag. Without them the Save button won\'t submit correctly.')}
      ${EX('&lt;form data-wdp-form="edit" data-wdp-id="\${_pk}"&gt;...&lt;/form&gt;')}

      ${H('$update[table.field] — Auto-rendered input')}
      ${P('Generates the right input widget for the field — text box, textarea, date picker, dropdown, checkbox, etc. — pre-filled with the current value. The <code>name</code> attribute is set automatically.')}
      ${EX('$update[books.title]\n$update[books.type]\n$update[books.long_description]')}

      ${H('Save & cancel buttons')}
      ${EX('&lt;button type="submit"&gt;Save&lt;/button&gt;\n&lt;button type="button" data-wdp-action="back"&gt;Cancel&lt;/button&gt;')}
      ${N('After a successful save the widget returns to the detail view automatically.')}

      ${H('Record ownership tokens')}
      ${P('Show who created/last edited this record — useful as read-only info inside the form.')}
      ${EX('\${_meta.created_by}   Who first saved this record\n\${_meta.created_at}   When it was created\n\${_meta.updated_by}   Last editor\n\${_meta.updated_at}   Last edited time')}
      ${COMMON}
    </div>`,
  };

  let helpVisible = false;
  let currentTpl  = (activeBtn && activeBtn.dataset.tpl) || 'search_form';

  function updateHelp(tpl) {
    currentTpl = tpl;
    const panel = document.getElementById('help-panel');
    if (panel && helpVisible) panel.innerHTML = HELP[tpl] || '';
  }

  document.getElementById('help-toggle')?.addEventListener('click', () => {
    helpVisible = !helpVisible;
    const panel  = document.getElementById('help-panel');
    const toggle = document.getElementById('help-toggle');
    if (!panel) return;
    if (helpVisible) {
      panel.innerHTML = HELP[currentTpl] || '';
      panel.classList.remove('d-none');
      toggle.textContent = '✕ Help';
      toggle.style.color = '#0f172a';
    } else {
      panel.classList.add('d-none');
      toggle.textContent = '? Help';
      toggle.style.color = '';
    }
  });

  // ── Token insertion at cursor ─────────────────────────────────────────────
  let lastFocusedTextarea = document.querySelector('.tpl-textarea');

  document.querySelectorAll('.tpl-textarea').forEach(ta => {
    ta.addEventListener('focus', () => { lastFocusedTextarea = ta; });
  });

  document.querySelectorAll('.token-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const ta    = lastFocusedTextarea;
      const token = btn.dataset.token;
      if (!ta || !token) return;
      const start = ta.selectionStart;
      const end   = ta.selectionEnd;
      ta.value = ta.value.slice(0, start) + token + ta.value.slice(end);
      ta.selectionStart = ta.selectionEnd = start + token.length;
      ta.focus();
    });
  });

  // ── SQL section collapse (state persisted in localStorage per view) ─────
  const SQL_PREF_KEY = 'wdp_sql_{{ loginAt }}_{{ view.id }}';

  function setSqlExpanded(expanded) {
    const panel   = document.getElementById('sql-collapsible');
    const chevron = document.getElementById('sql-chevron');
    panel.style.display = expanded ? '' : 'none';
    chevron.className   = (expanded ? 'bi bi-chevron-down' : 'bi bi-chevron-right') + ' me-1 text-muted';
    try { localStorage.setItem(SQL_PREF_KEY, expanded ? '1' : '0'); } catch(e) {}
  }

  // Apply saved preference on load (overrides the server-rendered default)
  try {
    const saved = localStorage.getItem(SQL_PREF_KEY);
    if (saved !== null) setSqlExpanded(saved === '1');
  } catch(e) {}

  document.getElementById('sql-card-header').addEventListener('click', function() {
    setSqlExpanded(document.getElementById('sql-collapsible').style.display === 'none');
  });

  // Used by "Customize SQL" button — expand and persist
  function ensureSqlExpanded() { setSqlExpanded(true); }

  // ── SQL mode ─────────────────────────────────────────────────────────────
  const sqlEditor    = document.getElementById('sql-editor');
  const modeInput    = document.getElementById('query_mode_input');
  const customInput  = document.getElementById('custom_sql_input');
  const badgeEl      = document.getElementById('sql-mode-badge');
  const btnCustomize = document.getElementById('btn-customize-sql');
  const btnReset     = document.getElementById('btn-reset-sql');
  const hintEl       = document.getElementById('sql-hint');

  function setCustomMode(isCustom) {
    sqlEditor.readOnly = !isCustom;
    modeInput.value    = isCustom ? 'advanced_sql' : 'automatic';
    badgeEl.textContent = isCustom ? 'Custom SQL' : 'Auto-generated';
    badgeEl.className   = 'badge ms-2 ' + (isCustom ? 'bg-warning text-dark' : 'bg-light text-dark border');
    btnCustomize.style.display = isCustom ? 'none' : '';
    btnReset.style.display     = isCustom ? '' : 'none';
    hintEl.innerHTML = isCustom
      ? 'Custom SQL active. Column aliases become available as <code>${alias}</code> tokens in templates.'
      : 'Auto-generated from <code>${table.field}</code> tokens found in your templates.';
  }

  btnCustomize?.addEventListener('click', () => { ensureSqlExpanded(); setCustomMode(true); });

  btnReset?.addEventListener('click', async () => {
    await refreshSql();
    setCustomMode(false);
  });

  // Before form submit, sync custom SQL if in custom mode
  document.getElementById('editor-form')?.addEventListener('submit', () => {
    if (modeInput.value === 'advanced_sql') {
      customInput.value = sqlEditor.value;
    }
  });

  // ── Refresh SQL from templates ────────────────────────────────────────────
  async function refreshSql() {
    const templates = {};
    document.querySelectorAll('.tpl-textarea').forEach(ta => {
      templates[ta.dataset.tpl] = ta.value;
    });
    try {
      const res  = await fetch('/admin/views/{{ view.id }}/generate-sql', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify(templates)
      });
      const data = await res.json();
      if (data.error) {
        sqlEditor.value = '-- Error: ' + data.error;
      } else {
        sqlEditor.value = data.sql;
      }
    } catch (e) {
      sqlEditor.value = '-- Request failed: ' + e.message;
    }
  }

  document.getElementById('btn-refresh-sql')?.addEventListener('click', refreshSql);

  // ── AI Design ─────────────────────────────────────────────────────────────
  // Bootstrap JS loads after this script, so never instantiate bootstrap.Modal
  // at the top level — get it lazily inside handlers instead.

  document.getElementById('aiModal')?.addEventListener('show.bs.modal', () => {
    document.getElementById('ai-style-hint').value = '';
    const status = document.getElementById('ai-status');
    status.style.display = 'none';
    status.style.color   = '';
  });

  document.getElementById('btn-ai-go')?.addEventListener('click', async () => {
    const btnAiGo = document.getElementById('btn-ai-go');
    const aiStatus = document.getElementById('ai-status');
    const hint = document.getElementById('ai-style-hint').value.trim();

    btnAiGo.disabled = true;
    btnAiGo.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Generating…';
    aiStatus.style.display = 'block';
    aiStatus.style.color   = '';
    aiStatus.textContent   = 'Calling AI — please wait. A large local model (qwen3.5) can take 2–5 minutes without a GPU. It is working…';

    // Tick up a live timer so the user knows it hasn't frozen
    let secs = 0;
    let timer = setInterval(() => {
      secs++;
      aiStatus.textContent = `Working… ${secs}s elapsed. Large local models can take 2–5 minutes without a GPU.`;
    }, 1000);

    try {
      const res  = await fetch('/admin/views/{{ view.id }}/generate-templates', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ style_hint: hint }),
      });
      const data = await res.json();

      if (data.error) {
        aiStatus.textContent = '✗ ' + data.error;
        aiStatus.style.color = '#991b1b';
      } else {
        let changed = 0;
        for (const [type, content] of Object.entries(data.templates)) {
          const ta = document.querySelector(`.tpl-textarea[data-tpl="${type}"]`);
          if (ta && ta.value !== content) { ta.value = content; changed++; }
        }
        bootstrap.Modal.getInstance(document.getElementById('aiModal'))?.hide();
        await refreshSql();
        // Notify live preview of the new template content
        document.querySelector('.tpl-textarea')?.dispatchEvent(new Event('input', { bubbles: true }));
        if (changed === 0) {
          console.info('[AI Design] Templates unchanged — model may need a style hint to produce different output.');
        }
      }
    } catch (e) {
      aiStatus.textContent = '✗ Request failed: ' + e.message;
      aiStatus.style.color = '#991b1b';
    } finally {
      clearInterval(timer);
      btnAiGo.disabled = false;
      btnAiGo.innerHTML = '<i class="bi bi-stars me-1"></i>Generate templates';
    }
  });
})();

// ── Live Preview ──────────────────────────────────────────────────────────────
(function () {
  const RENDER_URL = '/admin/views/{{ view.id }}/preview-render';
  let previewWin   = null;
  let debounceTimer = null;
  let popupBlobUrl  = null;

  // Build the popup page as a blob.
  // The popup stores current templates locally and handles search/pagination
  // by calling preview-render directly — giving real-time template preview
  // AND working search/pagination without embed.js.
  function getPopupUrl() {
    if (popupBlobUrl) return popupBlobUrl;
    const cssHref   = window.location.origin + '/static/widget-base.css';
    const renderUrl = RENDER_URL;
    const lines = [
      '<!DOCTYPE html><html lang="en"><head>',
      '<meta charset="UTF-8">',
      '<meta name="viewport" content="width=device-width,initial-scale=1">',
      '<title>Live Preview</title>',
      '<link rel="stylesheet" href="' + cssHref + '">',
      '<style>',
      'body{margin:0;padding:12px;font-family:system-ui,sans-serif;background:#f8fafc;}',
      '#wdp-status{font-size:.75rem;color:#94a3b8;text-align:center;padding:8px;}',
      '#wdp-status.hidden{display:none;}',
      '</style>',
      '</head><body>',
      '<div id="wdp-status">Waiting for preview\u2026</div>',
      '<div id="wdp-content"></div>',
      '<script>',
      'var _url=' + JSON.stringify(renderUrl) + ';',
      'var _tpl=null;',
      'var _st=new URLSearchParams({mode:"list",page:"1"});',

      // Receive rendered HTML + templates from editor
      'window.addEventListener("message",function(e){',
      '  if(!e.data||e.data.type!=="wdp-preview")return;',
      '  document.getElementById("wdp-status").classList.add("hidden");',
      '  document.getElementById("wdp-content").innerHTML=e.data.html;',
      '  if(e.data.templates)_tpl=e.data.templates;',
      '  _st=new URLSearchParams({mode:"list",page:"1"});',
      '});',

      // Re-fetch with current templates + query state
      'function _fetch(){',
      '  if(!_tpl)return;',
      '  fetch(_url+"?"+_st.toString(),{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify(_tpl)})',
      '  .then(function(r){return r.json();})',
      '  .then(function(d){',
      '    if(d.html)document.getElementById("wdp-content").innerHTML=d.html;',
      '    else if(d.error)document.getElementById("wdp-content").innerHTML=\'<p style="color:red;padding:12px;font-family:monospace">\'+d.error+\'</p>\';',
      '  });',
      '}',

      // Search form submit
      'document.addEventListener("submit",function(e){',
      '  var form=e.target.closest("[data-wdp-form=\\"search\\"]");',
      '  if(!form)return;',
      '  e.preventDefault();',
      '  _st=new URLSearchParams({mode:"list",page:"1"});',
      '  var q=form.querySelector("[name=q]");',
      '  if(q&&q.value)_st.set("q",q.value);',
      '  new FormData(form).forEach(function(v,k){if(k!=="q"&&String(v).trim())_st.set("f_"+k,String(v));});',
      '  _fetch();',
      '});',

      // Pagination, sort, clear
      'document.addEventListener("click",function(e){',
      '  var el=e.target.closest("[data-wdp-action]");',
      '  if(!el)return;',
      '  var act=el.dataset.wdpAction;',
      '  if(act==="page"){e.preventDefault();_st.set("page",el.dataset.wdpPage||"1");_fetch();}',
      '  else if(act==="clear"){e.preventDefault();_st=new URLSearchParams({mode:"list",page:"1"});_fetch();}',
      '  else if(act==="sort"){e.preventDefault();var f=el.dataset.wdpField,d=(_st.get("sort")===f&&_st.get("dir")==="asc")?"desc":"asc";_st.set("sort",f);_st.set("dir",d);_st.set("page","1");_fetch();}',
      '});',
      '<\/script>',
      '</body></html>'
    ];
    const blob = new Blob([lines.join('')], { type: 'text/html' });
    popupBlobUrl = URL.createObjectURL(blob);
    return popupBlobUrl;
  }

  function collectTemplates() {
    const data = {};
    document.querySelectorAll('textarea[name]').forEach(ta => {
      data[ta.name] = ta.value;
    });
    return data;
  }

  async function pushPreview() {
    if (!previewWin || previewWin.closed) return;
    try {
      const templates = collectTemplates();
      const res  = await fetch(RENDER_URL, {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify(templates),
      });
      const { html, error } = await res.json();
      if (error) {
        previewWin.postMessage({ type: 'wdp-preview', html: '<p style="color:red;padding:12px;font-family:monospace">Error: ' + error + '</p>' }, '*');
        return;
      }
      // Pass both rendered HTML and raw templates so popup can re-fetch on interaction
      previewWin.postMessage({ type: 'wdp-preview', html, templates }, '*');
    } catch (e) {
      previewWin.postMessage({ type: 'wdp-preview', html: '<p style="color:red;padding:12px;font-family:monospace">Request failed: ' + e.message + '</p>' }, '*');
    }
  }

  function schedulePush() {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(pushPreview, 450);
  }

  document.addEventListener('input', function(e) {
    if (e.target.matches('textarea.tpl-textarea')) schedulePush();
  });

  document.getElementById('btn-live-preview').addEventListener('click', function() {
    if (!previewWin || previewWin.closed) {
      previewWin = window.open(getPopupUrl(), 'wdp-live-preview',
        'width=860,height=700,left=100,top=80,resizable=yes,scrollbars=yes');
      setTimeout(pushPreview, 800);
    } else {
      previewWin.focus();
      pushPreview();
    }
  });
})();
</script>
{% endblock %}
