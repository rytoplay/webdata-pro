{% extends "admin/layout.njk" %}
{% block content %}
<div class="page-header">
  <h1>Views</h1>
  <a href="/admin/views/new" class="btn btn-sm btn-primary">
    <i class="bi bi-plus-lg me-1"></i>New View
  </a>
</div>

{% if flash %}
<div class="alert alert-{{ flash.type }} alert-dismissible fade show">
  {{ flash.message }}
  <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
{% endif %}

{% if views.length === 0 %}
<div class="card shadow-sm">
  <div class="card-body text-center py-5">
    <i class="bi bi-layout-text-window fs-1 text-muted d-block mb-2"></i>
    <p class="text-muted mb-3">No views yet. Create one to build a public-facing report.</p>
    <a href="/admin/views/new" class="btn btn-primary btn-sm">
      <i class="bi bi-plus-lg me-1"></i>New View
    </a>
  </div>
</div>
{% else %}
<div class="card shadow-sm">
  <table class="table table-hover mb-0">
    <thead class="table-light">
      <tr>
        <th>Label</th>
        <th>URL slug</th>
        <th>Base table</th>
        <th>Access</th>
        <th>Embed snippet</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      {% for view in views %}
      {% set bt = tableById.get(view.base_table_id) %}
      <tr>
        <td><strong>{{ view.label }}</strong></td>
        <td><code>{{ view.view_name }}</code></td>
        <td><code>{{ bt.table_name if bt else '—' }}</code></td>
        <td>
          {% if view.is_public %}
          <span class="badge bg-success">Public</span>
          {% else %}
          <span class="badge bg-secondary">Members only</span>
          {% endif %}
        </td>
        <td style="max-width:320px;">
          {% set snippet = '<div id="wdp-' + view.view_name + '"></div>\n<script src="' + baseUrl + '/static/embed.js"></script>\n<script>WDP.mount(\'#wdp-' + view.view_name + '\', {app:\'' + currentApp.slug + '\', view:\'' + view.view_name + '\', baseUrl:\'' + baseUrl + '\'});\n<\/script>' %}
          <div class="d-flex align-items-center gap-1">
            <code id="snip-{{ view.id }}" style="font-size:0.68rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; display:block; max-width:260px;" title="{{ snippet }}">{{ snippet }}</code>
            <button type="button" class="btn btn-sm btn-outline-secondary flex-shrink-0 py-0 px-1"
              style="font-size:.7rem;"
              onclick="navigator.clipboard.writeText(document.getElementById('snip-{{ view.id }}').title)"
              data-bs-toggle="tooltip" title="Copy embed snippet">
              <i class="bi bi-clipboard"></i>
            </button>
          </div>
        </td>
        <td class="text-end" style="white-space:nowrap;">
          <a href="/admin/views/{{ view.id }}/templates"
            class="btn btn-sm btn-outline-primary me-1"
            data-bs-toggle="tooltip" title="Edit templates">
            <i class="bi bi-pencil"></i>
          </a>
          <a href="/admin/views/{{ view.id }}/preview"
            class="btn btn-sm btn-outline-info me-1"
            data-bs-toggle="tooltip" title="Preview">
            <i class="bi bi-eye"></i>
          </a>
          <a href="/admin/views/{{ view.id }}/edit"
            class="btn btn-sm btn-outline-secondary me-1"
            data-bs-toggle="tooltip" title="Settings">
            <i class="bi bi-gear"></i>
          </a>
          <form method="POST" action="/admin/views/{{ view.id }}/delete" class="d-inline"
            onsubmit="return confirm('Delete view {{ view.label }}?')">
            <button class="btn btn-sm btn-outline-danger"
              data-bs-toggle="tooltip" title="Delete">
              <i class="bi bi-trash"></i>
            </button>
          </form>
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% endif %}
<script>
document.addEventListener('DOMContentLoaded', function() {
  document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function(el) {
    new bootstrap.Tooltip(el);
  });
});
</script>
{% endblock %}
