{% extends "admin/layout.njk" %}
{% block content %}
<div class="page-header">
  <h1>{{ view.label }} <span class="text-muted fw-normal fs-6">/ preview</span></h1>
  <div class="d-flex gap-2">
    <a href="/admin/views/{{ view.id }}/templates" class="btn btn-sm btn-outline-secondary">
      &larr; Templates
    </a>
  </div>
</div>

<div class="card shadow-sm">
  <div class="card-header py-2 d-flex align-items-center gap-2">
    <span class="text-muted small">Live preview — rendered by embed.js</span>
    <code class="ms-auto small text-muted">WDP.mount('#wdp-preview', { app: '{{ currentApp.slug }}', view: '{{ view.view_name }}' })</code>
  </div>
  <div class="card-body p-3">
    <div id="wdp-preview"></div>
  </div>
</div>

<script src="/static/embed.js"></script>
<script>
  WDP.mount('#wdp-preview', {
    app:     '{{ currentApp.slug }}',
    view:    '{{ view.view_name }}',
    baseUrl: ''
  });
</script>
{% endblock %}
