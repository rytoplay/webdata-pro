{% extends "admin/layout.njk" %}

{% block content %}
<div class="page-header">
  <h1>{{ table.label }}</h1>
  <div class="d-flex gap-2 align-items-center">
    {% if tableExists %}
    <a href="/admin/data/{{ table.table_name }}/new" class="btn btn-primary btn-sm">
      <i class="bi bi-plus-lg me-1"></i>Add Record
    </a>
    <a href="/admin/data/{{ table.table_name }}/import" class="btn btn-sm btn-outline-secondary">
      <i class="bi bi-filetype-csv me-1"></i>Import CSV
    </a>
    {% endif %}
    <a href="/admin/tables" class="btn btn-sm btn-outline-secondary">
      <i class="bi bi-table me-1"></i>Tables
    </a>
  </div>
</div>

{% if not tableExists %}

<div class="alert alert-warning d-flex align-items-center gap-3">
  <i class="bi bi-exclamation-triangle-fill fs-5"></i>
  <div>
    The table <strong>{{ table.table_name }}</strong> doesn't exist in the database.
    Try deleting and recreating it from the <a href="/admin/tables" class="alert-link">Tables</a> screen.
  </div>
</div>

{% else %}

<form method="GET" action="/admin/data/{{ table.table_name }}" class="mb-3 d-flex gap-2" style="max-width:480px;">
  <div class="input-group">
    <span class="input-group-text"><i class="bi bi-search"></i></span>
    <input type="text" class="form-control" name="q" value="{{ q }}" placeholder="Search…" autofocus>
    {% if q %}
    <a href="/admin/data/{{ table.table_name }}" class="btn btn-outline-secondary" title="Clear search">
      <i class="bi bi-x-lg"></i>
    </a>
    {% endif %}
  </div>
  <button type="submit" class="btn btn-outline-primary">Search</button>
</form>

{% if records.length === 0 and not q %}

<div class="card shadow-sm">
  <div class="card-body text-center py-5">
    <i class="bi bi-inbox fs-1 text-muted d-block mb-2"></i>
    <p class="text-muted mb-3">No records in <strong>{{ table.label }}</strong> yet.</p>
    <a href="/admin/data/{{ table.table_name }}/new" class="btn btn-primary btn-sm">
      <i class="bi bi-plus-lg me-1"></i>Add First Record
    </a>
  </div>
</div>

{% elif records.length === 0 and q %}

<div class="card shadow-sm">
  <div class="card-body text-center py-5">
    <i class="bi bi-search fs-1 text-muted d-block mb-2"></i>
    <p class="text-muted mb-0">No records match <strong>{{ q }}</strong>.</p>
  </div>
</div>

{% else %}

<div class="card shadow-sm">
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead class="table-light">
        <tr>
          {% for field in fields %}
            {% if field.ui_widget !== 'hidden' or field.is_primary_key %}
            <th>{{ field.label }}</th>
            {% endif %}
          {% endfor %}
          <th style="width:100px;"></th>
        </tr>
      </thead>
      <tbody>
        {% for record in records %}
        <tr>
          {% for field in fields %}
            {% if field.ui_widget !== 'hidden' or field.is_primary_key %}
            <td style="max-width:280px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
              {% set val = record[field.field_name] %}
              {% if val === null or val === undefined or val === '' %}
                <span class="text-muted" style="font-size:0.8rem;">—</span>
              {% elif field.ui_widget === 'checkbox' or field.data_type === 'boolean' %}
                {% if val %}
                  <i class="bi bi-check-circle-fill text-success"></i>
                {% else %}
                  <i class="bi bi-circle text-muted"></i>
                {% endif %}
              {% elif field.is_primary_key %}
                <span class="text-muted" style="font-size:0.8rem;">{{ val }}</span>
              {% else %}
                {{ val }}
              {% endif %}
            </td>
            {% endif %}
          {% endfor %}
          <td class="text-end" style="white-space:nowrap;">
            {% if pkField %}
            <a href="/admin/data/{{ table.table_name }}/{{ record[pkField.field_name] }}/edit"
               class="btn btn-sm btn-outline-primary me-1">
              <i class="bi bi-pencil"></i>
            </a>
            <form method="POST"
              action="/admin/data/{{ table.table_name }}/{{ record[pkField.field_name] }}/delete"
              class="d-inline"
              onsubmit="return confirm('Delete this record?')">
              <button class="btn btn-sm btn-outline-danger">
                <i class="bi bi-trash"></i>
              </button>
            </form>
            {% endif %}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% if records.length >= 200 %}
  <div class="card-footer text-muted" style="font-size:0.8rem;">
    Showing first 200 results{% if q %} for <strong>{{ q }}</strong>{% endif %}.
  </div>
  {% else %}
  <div class="card-footer text-muted" style="font-size:0.8rem;">
    {% if q %}
      {{ records.length }} result{{ 's' if records.length !== 1 else '' }} for <strong>{{ q }}</strong>
    {% else %}
      {{ records.length }} record{{ 's' if records.length !== 1 else '' }}
    {% endif %}
  </div>
  {% endif %}
</div>

{% endif %}

{% endif %}
{% endblock %}
