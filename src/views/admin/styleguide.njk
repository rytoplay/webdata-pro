&lt;<span class="hl">div</span> class=<span class="str">"wdp"</span>&gt;&lt;<span class="hl">form</span> data-wdp-form=<span class="str">"search"</span>&gt;
  &lt;<span class="hl">div</span> class=<span class="str">"wdp-sf"</span>&gt;
    &lt;<span class="hl">input</span> type=<span class="str">"text"</span> name=<span class="str">"q"</span> value=<span class="str">"${_q}"</span> placeholder=<span class="str">"Search pets…"</span>&gt;
    &lt;<span class="hl">button</span> type=<span class="str">"submit"</span>&gt;Search&lt;/<span class="hl">button</span>&gt;
