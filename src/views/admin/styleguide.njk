&lt;/<span class="hl">div</span>&gt;

&lt;!-- ROW --&gt;
&lt;<span class="hl">div</span> class=<span class="str">"wdp-row"</span> data-wdp-action=<span class="str">"detail"</span> data-wdp-id=<span class="str">"${_pk}"</span>&gt;
