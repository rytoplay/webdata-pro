&lt;!-- FOOTER --&gt;
&lt;<span class="hl">div</span> class=<span class="str">"wdp-footer"</span>&gt;${_pagination}&lt;/<span class="hl">div</span>&gt;&lt;/<span class="hl">div</span>&gt;</pre>
