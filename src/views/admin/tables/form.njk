{% extends "admin/layout.njk" %}

{% block content %}
<div class="page-header">
  <h1>{{ title }}</h1>
  <a href="/admin/tables" class="btn btn-sm btn-outline-secondary">&larr; Back</a>
</div>

<div class="card shadow-sm" style="max-width:580px">
  <div class="card-body p-4">
    <form method="POST" action="{% if table and table.id %}/admin/tables/{{ table.id }}{% else %}/admin/tables{% endif %}">

      <div class="row g-3 mb-3">
        <div class="col-md-6">
          <label class="form-label">Table name <span class="text-danger">*</span></label>
          <input type="text" name="table_name"
            class="form-control {% if errors.table_name %}is-invalid{% endif %}"
            value="{{ table.table_name if table else '' }}"
            placeholder="e.g. books" required>
          {% if errors.table_name %}
          <div class="invalid-feedback">{{ errors.table_name[0] }}</div>
          {% endif %}
          <div class="form-text">Lowercase letters, numbers, underscores only.</div>
        </div>
        <div class="col-md-6">
          <label class="form-label">Label <span class="text-danger">*</span></label>
          <input type="text" name="label"
            class="form-control {% if errors.label %}is-invalid{% endif %}"
            value="{{ table.label if table else '' }}"
            placeholder="e.g. Books" required>
          {% if errors.label %}
          <div class="invalid-feedback">{{ errors.label[0] }}</div>
          {% endif %}
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label">Description</label>
        <textarea name="description" class="form-control" rows="2">{{ table.description if table else '' }}</textarea>
      </div>

      <div class="mb-4">
        <div class="form-check">
          <input type="checkbox" name="is_public_addable" value="true"
            class="form-check-input" id="pubAdd"
            {% if table and table.is_public_addable %}checked{% endif %}>
          <label class="form-check-label" for="pubAdd">Public can add records</label>
          <div class="form-text">Allow unauthenticated visitors to submit new records.</div>
        </div>
      </div>

      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">
          {% if table and table.id %}Save Changes{% else %}Create Table{% endif %}
        </button>
        <a href="/admin/tables" class="btn btn-outline-secondary">Cancel</a>
      </div>
    </form>
  </div>
</div>
{% endblock %}
