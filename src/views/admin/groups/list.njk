{% extends "admin/layout.njk" %}

{% block content %}
<div class="page-header">
  <h1>Groups</h1>
  <a href="/admin/groups/new" class="btn btn-primary btn-sm">
    <i class="bi bi-plus-lg me-1"></i>New Group
  </a>
</div>

{% if flash %}
<div class="alert alert-{{ flash.type }} alert-dismissible fade show" role="alert">
  {{ flash.message }}
  <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
{% endif %}

{% if groups.length === 0 %}
<div class="text-center text-muted py-5">
  <i class="bi bi-people fs-1 d-block mb-2"></i>
  No groups yet. <a href="/admin/groups/new">Create one</a>.
</div>
{% else %}
<div class="card shadow-sm">
  <table class="table table-hover mb-0">
    <thead class="table-light">
      <tr>
        <th>Name</th>
        <th>Description</th>
        <th>Self-register</th>
        <th>2FA required</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      {% for g in groups %}
      <tr>
        <td><strong>{{ g.group_name }}</strong></td>
        <td class="text-muted">{{ g.description or '—' }}</td>
        <td>
          {% if g.self_register_enabled %}
            <i class="bi bi-check-circle text-success"></i>
          {% else %}
            <i class="bi bi-x-circle text-muted"></i>
          {% endif %}
        </td>
        <td>
          {% if g.tfa_required %}
            <i class="bi bi-check-circle text-success"></i>
          {% else %}
            <i class="bi bi-x-circle text-muted"></i>
          {% endif %}
        </td>
        <td class="text-end">
          <a href="/admin/groups/{{ g.id }}/edit" class="btn btn-sm btn-outline-primary me-1">
            <i class="bi bi-pencil"></i> Edit
          </a>
          <form method="POST" action="/admin/groups/{{ g.id }}/delete" class="d-inline"
            onsubmit="return confirm('Delete group {{ g.group_name }}?')">
            <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
          </form>
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% endif %}
{% endblock %}
