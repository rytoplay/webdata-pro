{% extends "admin/layout.njk" %}

{% block content %}
<div class="page-header">
  <h1>{{ title }}</h1>
  <a href="/admin/groups" class="btn btn-sm btn-outline-secondary">&larr; Groups</a>
</div>

{% if flash %}
<div class="alert alert-{{ flash.type }} alert-dismissible fade show" role="alert">
  {{ flash.message }}
  <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
{% endif %}

{# ── Settings form ──────────────────────────────────────────────────────────── #}
<div class="card shadow-sm mb-4" style="max-width:680px;">
  <div class="card-header"><strong>Group Settings</strong></div>
  <div class="card-body p-4">
    <form method="POST" action="{{ '/admin/groups/' + group.id + '/edit' if group and group.id else '/admin/groups' }}">

      <div class="mb-3">
        <label class="form-label">Name <span class="text-danger">*</span></label>
        <input type="text" name="group_name" class="form-control"
          value="{{ group.group_name if group else '' }}" required>
        {% if errors and errors.group_name %}
        <div class="text-danger small">{{ errors.group_name[0] }}</div>
        {% endif %}
      </div>

      <div class="mb-3">
        <label class="form-label">Description</label>
        <textarea name="description" class="form-control" rows="2">{{ group.description if group else '' }}</textarea>
      </div>

      <div class="mb-3">
        <label class="form-label">Default home view</label>
        <select name="default_home_view_id" class="form-select">
          <option value="">— none —</option>
          {% for v in views %}
          <option value="{{ v.id }}"
            {% if group and group.default_home_view_id == v.id %}selected{% endif %}>
            {{ v.label }}
          </option>
          {% endfor %}
        </select>
        <div class="form-text">Where members land after login.</div>
      </div>

      <div class="mb-3">
        <div class="form-check">
          <input class="form-check-input" type="checkbox" name="self_register_enabled" id="self_reg" value="on"
            {% if group and group.self_register_enabled %}checked{% endif %}>
          <label class="form-check-label" for="self_reg">
            Allow self-registration
          </label>
        </div>
        <div class="form-check mt-1">
          <input class="form-check-input" type="checkbox" name="tfa_required" id="tfa_req" value="on"
            {% if group and group.tfa_required %}checked{% endif %}>
          <label class="form-check-label" for="tfa_req">
            Require two-factor authentication
          </label>
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold" for="post_logout_url">Post-logout URL <span class="text-muted fw-normal">(optional)</span></label>
        <input type="url" class="form-control" name="post_logout_url" id="post_logout_url"
          placeholder="https://yourwebsite.com"
          value="{{ group.post_logout_url or '' }}">
        <div class="form-text">Where to send members after they sign out. Leave blank to redirect to this app's login page.</div>
      </div>

      <div class="d-flex gap-2 pt-2">
        <button type="submit" class="btn btn-primary">
          {% if group and group.id %}Save Settings{% else %}Create Group{% endif %}
        </button>
        <a href="/admin/groups" class="btn btn-outline-secondary">Cancel</a>
      </div>

    </form>
  </div>
</div>

{# ── Self-registration URLs (only when enabled and group is saved) ──────────── #}
{% if group and group.id and group.self_register_enabled %}
<div class="card shadow-sm mb-4 border-success" style="max-width:680px;">
  <div class="card-header text-success"><strong>Self-Registration Links</strong></div>
  <div class="card-body">
    <p class="text-muted small mb-3">Share these URLs with people you want to sign up for this group.</p>

    <div class="mb-3">
      <label class="form-label fw-semibold">Login page</label>
      <div class="input-group">
        <input type="text" class="form-control font-monospace"
          value="{{ baseUrl }}/app/{{ currentApp.slug }}/login" readonly id="url-login">
        <button class="btn btn-outline-secondary" type="button"
          onclick="navigator.clipboard.writeText(document.getElementById('url-login').value)">Copy</button>
      </div>
    </div>

    <div class="mb-4">
      <label class="form-label fw-semibold">Registration page</label>
      <div class="input-group">
        <input type="text" class="form-control font-monospace"
          value="{{ baseUrl }}/app/{{ currentApp.slug }}/register" readonly id="url-register">
        <button class="btn btn-outline-secondary" type="button"
          onclick="navigator.clipboard.writeText(document.getElementById('url-register').value)">Copy</button>
      </div>
    </div>

    <div>
      <label class="form-label fw-semibold">Embed snippet</label>
      <p class="text-muted small">Paste into any static HTML page to link visitors directly to registration:</p>
      <pre class="bg-light border rounded p-3" style="font-size:.8rem; white-space:pre-wrap;">&lt;a href="/app/{{ currentApp.slug }}/register"&gt;Create an account&lt;/a&gt;
&lt;a href="/app/{{ currentApp.slug }}/login"&gt;Sign in&lt;/a&gt;</pre>
    </div>
  </div>
</div>
{% endif %}

{# ── Home template editor (only on edit) ─────────────────────────────────────── #}
{% if group and group.id %}

<div class="row g-3 mb-4" style="max-width:960px;">
  <div class="col-lg-8">
    <form method="POST" action="/admin/groups/{{ group.id }}/edit">
      {# Re-submit required group fields so partial form doesn't wipe them #}
      <input type="hidden" name="group_name" value="{{ group.group_name }}">
      <input type="hidden" name="description" value="{{ group.description or '' }}">
      {% if group.self_register_enabled %}<input type="hidden" name="self_register_enabled" value="on">{% endif %}
      {% if group.tfa_required %}<input type="hidden" name="tfa_required" value="on">{% endif %}
      <input type="hidden" name="default_home_view_id" value="{{ group.default_home_view_id or '' }}">
      <input type="hidden" name="post_logout_url" value="{{ group.post_logout_url or '' }}">

      <div class="card shadow-sm">
        <div class="card-header d-flex align-items-center gap-2 py-2">
          <ul class="nav nav-tabs card-header-tabs mb-0" id="tpl-tabs">
            <li class="nav-item">
              <button type="button" class="nav-link py-1 px-3" data-tpl-tab="header">Header</button>
            </li>
            <li class="nav-item">
              <button type="button" class="nav-link active py-1 px-3" data-tpl-tab="body">Content</button>
            </li>
            <li class="nav-item">
              <button type="button" class="nav-link py-1 px-3" data-tpl-tab="footer">Footer</button>
            </li>
          </ul>
          <a href="/admin/groups/{{ group.id }}/preview-home" target="_blank"
            class="btn btn-sm btn-outline-primary ms-auto">Preview</a>
          <button type="button" class="btn btn-sm btn-outline-secondary" id="btn-reset-home">Reset</button>
        </div>

        <div class="card-body p-0">
          <div class="tpl-hint px-3 pt-2 pb-1 text-muted" style="font-size:0.75rem;" id="hint-header">
            CSS, opening HTML, nav — rendered before the content template.
          </div>
          <div class="tpl-hint px-3 pt-2 pb-1 text-muted d-none" style="font-size:0.75rem;" id="hint-body">
            The main homepage content. Use <code>embedView()</code>, member variables, etc.
          </div>
          <div class="tpl-hint px-3 pt-2 pb-1 text-muted d-none" style="font-size:0.75rem;" id="hint-footer">
            Closing HTML, footer content — rendered after the content template.
          </div>

          <textarea name="home_header_html" id="tpl-header"
            class="tpl-editor form-control font-monospace border-0 rounded-0 d-none"
            rows="16" style="resize:vertical; font-size:0.82rem; tab-size:2;"
            placeholder="Optional — CSS and opening HTML go here.">{{ group.home_header_html or '' }}</textarea>

          <textarea name="home_template" id="tpl-body"
            class="tpl-editor form-control font-monospace border-0 rounded-0"
            rows="16" style="resize:vertical; font-size:0.82rem; tab-size:2;"
            placeholder="Leave blank to show the default view list.">{{ group.home_template or '' }}</textarea>

          <textarea name="home_footer_html" id="tpl-footer"
            class="tpl-editor form-control font-monospace border-0 rounded-0 d-none"
            rows="16" style="resize:vertical; font-size:0.82rem; tab-size:2;"
            placeholder="Optional — closing tags and footer content go here.">{{ group.home_footer_html or '' }}</textarea>
        </div>

        <div class="card-footer d-flex justify-content-between align-items-center">
          <button type="submit" class="btn btn-primary btn-sm">Save Template</button>
          <span class="text-muted small">Leave blank to show the default view list.</span>
        </div>
      </div>
    </form>
  </div>

  <div class="col-lg-4">
    <div class="card shadow-sm" style="font-size:0.8rem;">

      {# Tab header #}
      <div class="card-header p-0" style="border-bottom:1px solid #e2e8f0;">
        <div class="d-flex align-items-center justify-content-between ps-1 pe-2" style="padding-top:5px;">
          <div class="d-flex">
            <button type="button" class="grp-tab-btn" data-panel="tags"
              style="background:none;border:none;border-bottom:2px solid var(--accent);color:var(--accent);font-weight:600;font-size:0.78rem;cursor:pointer;padding:2px 12px 5px;">
              Tags
            </button>
            <button type="button" class="grp-tab-btn" data-panel="blocks"
              style="background:none;border:none;border-bottom:2px solid transparent;color:#64748b;font-weight:400;font-size:0.78rem;cursor:pointer;padding:2px 12px 5px;">
              Blocks
            </button>
          </div>
          <a href="/admin/styleguide" target="_blank" class="text-muted" style="font-size:0.7rem;">Style guide ↗</a>
        </div>
      </div>

      {# Tags pane #}
      <div id="grp-panel-tags" style="overflow-y:auto;max-height:520px;scrollbar-width:thin;scrollbar-color:#cbd5e1 transparent;">
        <div class="p-2">

          <div class="text-muted mb-1" style="font-size:0.7rem;">APP</div>
          {% set appTags = [
            ['{{ app.name }}',  'App name'],
            ['{{ app.slug }}',  'App slug / URL key']
          ] %}
          {% for t in appTags %}
          <button type="button" class="grp-tag-btn w-100 text-start mb-1 p-1 rounded"
            data-token="{{ t[0] }}"
            style="background:var(--accent-soft);color:var(--accent);border:none;font-family:monospace;font-size:0.75rem;padding:3px 6px;cursor:pointer;">
            <div>{{ t[0] }}</div>
            <div style="font-family:system-ui,sans-serif;font-size:0.63rem;color:#64748b;">{{ t[1] }}</div>
          </button>
          {% endfor %}

          <div class="text-muted mt-2 mb-1" style="font-size:0.7rem;">MEMBER</div>
          {% set memberTags = [
            ['{{ member.first_name }}', 'First name'],
            ['{{ member.last_name }}',  'Last name'],
            ['{{ member.email }}',      'Email address'],
            ['{{ logoutUrl }}',         'Sign-out URL']
          ] %}
          {% for t in memberTags %}
          <button type="button" class="grp-tag-btn w-100 text-start mb-1 p-1 rounded"
            data-token="{{ t[0] }}"
            style="background:#f0fdf4;color:#166534;border:none;font-family:monospace;font-size:0.75rem;padding:3px 6px;cursor:pointer;">
            <div>{{ t[0] }}</div>
            <div style="font-family:system-ui,sans-serif;font-size:0.63rem;color:#64748b;">{{ t[1] }}</div>
          </button>
          {% endfor %}

          <div class="text-muted mt-2 mb-1" style="font-size:0.7rem;">VIEWS (loop variables)</div>
          {% set viewTags = [
            ['{{ v.label }}',     'Display name'],
            ['{{ v.url }}',       'Ready-to-use link'],
            ['{{ v.view_name }}', 'Internal view name']
          ] %}
          {% for t in viewTags %}
          <button type="button" class="grp-tag-btn w-100 text-start mb-1 p-1 rounded"
            data-token="{{ t[0] }}"
            style="background:#eff6ff;color:#1e40af;border:none;font-family:monospace;font-size:0.75rem;padding:3px 6px;cursor:pointer;">
            <div>{{ t[0] }}</div>
            <div style="font-family:system-ui,sans-serif;font-size:0.63rem;color:#64748b;">{{ t[1] }}</div>
          </button>
          {% endfor %}

          <div class="text-muted mt-2 mb-1" style="font-size:0.7rem;">TABLES (loop variables)</div>
          {% set tableTags = [
            ['{{ t.label }}',    'Display name'],
            ['{{ t.tableUrl }}', 'List / browse URL'],
            ['{{ t.newUrl }}',   'Add record URL']
          ] %}
          {% for t in tableTags %}
          <button type="button" class="grp-tag-btn w-100 text-start mb-1 p-1 rounded"
            data-token="{{ t[0] }}"
            style="background:#fef9c3;color:#713f12;border:none;font-family:monospace;font-size:0.75rem;padding:3px 6px;cursor:pointer;">
            <div>{{ t[0] }}</div>
            <div style="font-family:system-ui,sans-serif;font-size:0.63rem;color:#64748b;">{{ t[1] }}</div>
          </button>
          {% endfor %}

          <div class="mt-2 pt-2 border-top small text-muted" style="font-size:0.7rem;line-height:1.5;">
            <strong style="color:#374151;">Available arrays:</strong><br>
            <code style="font-size:0.68rem;">views</code> — all views<br>
            <code style="font-size:0.68rem;">browseViews</code> — read-only views<br>
            <code style="font-size:0.68rem;">manageViews</code> — edit/add views<br>
            <code style="font-size:0.68rem;">tables</code> — direct table access
          </div>

        </div>
      </div>

      {# Blocks pane #}
      <div id="grp-panel-blocks" class="d-none" style="overflow-y:auto;max-height:520px;scrollbar-width:thin;scrollbar-color:#cbd5e1 transparent;">
        <div class="p-2">

          <div class="text-muted mb-2" style="font-size:0.7rem;">A — COMPLETE SCAFFOLDS</div>

          <button type="button" class="grp-block-btn w-100 text-start mb-2 p-2 rounded" data-block="welcome-card"
            style="background:#f0fdf4;border:1px solid #86efac;cursor:pointer;">
            <div style="font-weight:600;font-size:0.78rem;color:#166534;">Welcome Card</div>
            <div style="font-size:0.67rem;color:#4b7c59;margin-top:2px;">greeting + member name + email</div>
          </button>

          <button type="button" class="grp-block-btn w-100 text-start mb-2 p-2 rounded" data-block="nav-sections"
            style="background:#f0fdf4;border:1px solid #86efac;cursor:pointer;">
            <div style="font-weight:600;font-size:0.78rem;color:#166534;">Full Nav Layout</div>
            <div style="font-size:0.67rem;color:#4b7c59;margin-top:2px;">Searches, Manage views, Tables — all sections</div>
          </button>

          <div class="text-muted mt-3 mb-2" style="font-size:0.7rem;">C — COMPOUND SNIPPETS</div>

          <button type="button" class="grp-block-btn w-100 text-start mb-2 p-2 rounded" data-block="views-loop"
            style="background:#eff6ff;border:1px solid #93c5fd;cursor:pointer;">
            <div style="font-weight:600;font-size:0.78rem;color:#1e40af;">Views Loop</div>
            <div style="font-size:0.67rem;color:#3b5fa0;margin-top:2px;">{% raw %}{% for v in views %}{% endraw %} links list</div>
          </button>

          <button type="button" class="grp-block-btn w-100 text-start mb-2 p-2 rounded" data-block="tables-loop"
            style="background:#eff6ff;border:1px solid #93c5fd;cursor:pointer;">
            <div style="font-weight:600;font-size:0.78rem;color:#1e40af;">Tables Loop</div>
            <div style="font-size:0.67rem;color:#3b5fa0;margin-top:2px;">{% raw %}{% for t in tables %}{% endraw %} with add/edit CTAs</div>
          </button>

          <button type="button" class="grp-block-btn w-100 text-start mb-2 p-2 rounded" data-block="sign-out-link"
            style="background:#eff6ff;border:1px solid #93c5fd;cursor:pointer;">
            <div style="font-weight:600;font-size:0.78rem;color:#1e40af;">Sign Out Link</div>
            <div style="font-size:0.67rem;color:#3b5fa0;margin-top:2px;">styled anchor using logoutUrl</div>
          </button>

          {% if views.length > 0 %}
          <div class="text-muted mt-3 mb-2" style="font-size:0.7rem;">D — INSERT SPECIFIC VIEW</div>
          {% for v in views %}
          <div class="d-flex align-items-center gap-1 mb-1">
            <span class="flex-grow-1 text-truncate" style="font-size:0.72rem;" title="{{ v.view_name }}">{{ v.label }}</span>
            <button type="button" class="btn btn-outline-primary py-0 px-1 wdp-insert"
              style="font-size:.68rem;"
              data-view="{{ v.view_name }}" data-mode="embed">Embed</button>
            <button type="button" class="btn btn-outline-secondary py-0 px-1 wdp-insert"
              style="font-size:.68rem;"
              data-view="{{ v.view_name }}" data-label="{{ v.label }}" data-mode="link">Link</button>
          </div>
          {% endfor %}
          {% endif %}

        </div>
      </div>

    </div>
  </div>
</div>

<script>
// ── Tab switching ────────────────────────────────────────────────────────────
let _activeEditor = document.getElementById('tpl-body');

document.querySelectorAll('[data-tpl-tab]').forEach(function(btn) {
  btn.addEventListener('click', function() {
    const tab = btn.dataset.tplTab;

    // Update tab button states
    document.querySelectorAll('[data-tpl-tab]').forEach(function(b) {
      b.classList.toggle('active', b.dataset.tplTab === tab);
    });

    // Show/hide textareas and hints
    ['header', 'body', 'footer'].forEach(function(t) {
      const ta   = document.getElementById('tpl-' + t);
      const hint = document.getElementById('hint-' + t);
      ta.classList.toggle('d-none', t !== tab);
      hint.classList.toggle('d-none', t !== tab);
    });

    _activeEditor = document.getElementById('tpl-' + tab);
    _activeEditor.focus();
  });
});

// ── Reset button resets only the Content tab ─────────────────────────────────
document.getElementById('btn-reset-home').addEventListener('click', function() {
  if (confirm('Reset Content template to the default?')) {
    document.getElementById('tpl-body').value = {{ defaultTemplate | dump | safe }};
  }
});

// ── Tab key indent in all three editors ──────────────────────────────────────
document.querySelectorAll('.tpl-editor').forEach(function(ta) {
  ta.addEventListener('keydown', function(e) {
    if (e.key === 'Tab') {
      e.preventDefault();
      const s = this.selectionStart;
      this.value = this.value.slice(0, s) + '  ' + this.value.slice(this.selectionEnd);
      this.selectionStart = this.selectionEnd = s + 2;
    }
  });
});

// ── Insert snippet into whichever tab is active ───────────────────────────────
function insertSnippet(text) {
  _activeEditor.focus();
  const s = _activeEditor.selectionStart;
  const e = _activeEditor.selectionEnd;
  _activeEditor.value = _activeEditor.value.slice(0, s) + text + _activeEditor.value.slice(e);
  _activeEditor.selectionStart = _activeEditor.selectionEnd = s + text.length;
}

document.querySelectorAll('.wdp-insert').forEach(function(btn) {
  btn.addEventListener('click', function() {
    const view  = btn.dataset.view;
    const label = btn.dataset.label || view;
    const mode  = btn.dataset.mode;
    const ob = '\x7b\x7b', cb = '\x7d\x7d';
    if (mode === 'embed') {
      insertSnippet(ob + " embedView('" + view + "') | safe " + cb);
    } else {
      insertSnippet('<a href="' + ob + " viewUrl('" + view + "') " + cb + '">' + label + '</a>');
    }
  });
});

// ── Reference panel: Tags/Blocks tab switcher ────────────────────────────────
document.querySelectorAll('.grp-tab-btn').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var panel = btn.dataset.panel;
    document.querySelectorAll('.grp-tab-btn').forEach(function(b) {
      var active = b.dataset.panel === panel;
      b.style.borderBottomColor = active ? 'var(--accent)' : 'transparent';
      b.style.color = active ? 'var(--accent)' : '#64748b';
      b.style.fontWeight = active ? '600' : '400';
    });
    document.getElementById('grp-panel-tags').classList.toggle('d-none', panel !== 'tags');
    document.getElementById('grp-panel-blocks').classList.toggle('d-none', panel !== 'blocks');
  });
});

// ── Tag click-to-insert ───────────────────────────────────────────────────────
document.querySelectorAll('.grp-tag-btn').forEach(function(btn) {
  btn.addEventListener('click', function() {
    insertSnippet(btn.dataset.token);
  });
});

// ── Block content library ─────────────────────────────────────────────────────
var GROUP_BLOCKS = {
  'welcome-card': [
    '<div style="background:#f0fdf4;border:1px solid #86efac;border-radius:8px;padding:1.25rem 1.5rem;margin-bottom:1.5rem;">',
    '  <h2 style="margin:0 0 0.4rem;font-size:1.25rem;">Welcome back, {{ member.first_name }}!</h2>',
    '  <p style="margin:0;color:#64748b;font-size:0.9rem;">{{ member.email }}</p>',
    '</div>'
  ].join('\n'),

  'nav-sections': [
    '<h2 style="font-size:1rem;font-weight:600;margin:1.5rem 0 0.5rem;">Searches &amp; Reports</h2>',
    '<ul style="list-style:none;padding:0;margin:0 0 1.5rem;">',
    '{% for v in browseViews %}',
    '  <li style="margin-bottom:0.4rem;"><a href="{{ v.url }}" style="color:var(--accent);">{{ v.label }}</a></li>',
    '{% endfor %}',
    '</ul>',
    '',
    '<h2 style="font-size:1rem;font-weight:600;margin:0 0 0.5rem;">Manage Data</h2>',
    '<ul style="list-style:none;padding:0;margin:0 0 1.5rem;">',
    '{% for v in manageViews %}',
    '  <li style="margin-bottom:0.4rem;"><a href="{{ v.url }}" style="color:var(--accent);">{{ v.label }}</a></li>',
    '{% endfor %}',
    '</ul>',
    '',
    '<h2 style="font-size:1rem;font-weight:600;margin:0 0 0.5rem;">Tables</h2>',
    '<ul style="list-style:none;padding:0;margin:0;">',
    '{% for t in tables %}',
    '  <li style="margin-bottom:0.5rem;">',
    '    <a href="{{ t.tableUrl }}" style="color:var(--accent);">{{ t.label }}</a>',
    '    {% if t.newUrl %}&ensp;<a href="{{ t.newUrl }}" style="font-size:0.82rem;color:#64748b;">+ Add</a>{% endif %}',
    '  </li>',
    '{% endfor %}',
    '</ul>'
  ].join('\n'),

  'views-loop': [
    '{% for v in views %}',
    '<a href="{{ v.url }}" style="display:inline-block;margin:0.25rem 0.5rem 0.25rem 0;padding:0.3rem 0.8rem;background:var(--accent-soft);color:var(--accent);border-radius:4px;text-decoration:none;font-size:0.9rem;">',
    '  {{ v.label }}',
    '</a>',
    '{% endfor %}'
  ].join('\n'),

  'tables-loop': [
    '{% for t in tables %}',
    '<div style="margin-bottom:0.75rem;">',
    '  <strong>{{ t.label }}</strong>',
    '  &ensp;<a href="{{ t.tableUrl }}">Browse</a>',
    '  {% if t.newUrl %}&ensp;<a href="{{ t.newUrl }}">Add Record</a>{% endif %}',
    '</div>',
    '{% endfor %}'
  ].join('\n'),

  'sign-out-link': '<a href="{{ logoutUrl }}" style="display:inline-block;padding:0.35rem 1rem;border:1px solid #94a3b8;border-radius:4px;color:#64748b;text-decoration:none;font-size:0.85rem;">Sign Out</a>'
};

document.querySelectorAll('.grp-block-btn').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var key = btn.dataset.block;
    if (!key || GROUP_BLOCKS[key] === undefined) return;
    insertSnippet(GROUP_BLOCKS[key]);
  });
});
</script>

{# ── Permissions grid ────────────────────────────────────────────────────────── #}
<form method="POST" action="/admin/groups/{{ group.id }}/permissions">

  {# Table permissions #}
  {% if tablePerm.length > 0 %}
  <div class="card shadow-sm mb-4">
    <div class="card-header d-flex align-items-center gap-2">
      <strong>Table Permissions</strong>
      <span class="text-muted small">— what members of this group can do</span>
    </div>
    <div class="table-responsive">
      <table class="table table-sm table-bordered mb-0 align-middle text-center" style="font-size:.85rem;">
        <thead class="table-light">
          <tr>
            <th class="text-start ps-3" style="min-width:160px;">Table</th>
            <th title="Can create new records">Add</th>
            <th title="Can edit records">Edit</th>
            <th title="Can delete records">Delete</th>
            <th title="Manage all records, not just their own">Manage All</th>
            <th title="Each member can have at most one record in this table">Single Record</th>
          </tr>
        </thead>
        <tbody>
          {% for row in tablePerm %}
          <tr>
            <td class="text-start ps-3">
              <strong>{{ row.label }}</strong>
              <div class="text-muted" style="font-size:.78rem;"><code>{{ row.table_name }}</code></div>
            </td>
            <td>
              <input type="checkbox" name="tp_{{ row.table_id }}_can_add" value="on"
                class="form-check-input" {% if row.can_add %}checked{% endif %}>
            </td>
            <td>
              <input type="checkbox" name="tp_{{ row.table_id }}_can_edit" value="on"
                class="form-check-input" {% if row.can_edit %}checked{% endif %}>
            </td>
            <td>
              <input type="checkbox" name="tp_{{ row.table_id }}_can_delete" value="on"
                class="form-check-input" {% if row.can_delete %}checked{% endif %}>
            </td>
            <td>
              <input type="checkbox" name="tp_{{ row.table_id }}_manage_all" value="on"
                class="form-check-input" {% if row.manage_all %}checked{% endif %}>
            </td>
            <td>
              <input type="checkbox" name="tp_{{ row.table_id }}_single_record" value="on"
                class="form-check-input" {% if row.single_record %}checked{% endif %}>
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    <div class="card-footer text-muted" style="font-size:.8rem;">
      <strong>Manage All</strong>: without this, members can only edit/delete records they created. &nbsp;|&nbsp;
      <strong>Single Record</strong>: each member may have at most one record in this table — views on this table go straight to their edit/create form.
    </div>
  </div>
  {% endif %}

  {# View permissions #}
  {% if viewPerm.length > 0 %}
  <div class="card shadow-sm mb-4">
    <div class="card-header d-flex align-items-center gap-2">
      <strong>View Permissions</strong>
      <span class="text-muted small">— which views members can access</span>
    </div>
    <div class="table-responsive">
      <table class="table table-sm table-bordered mb-0 align-middle text-center" style="font-size:.85rem;">
        <thead class="table-light">
          <tr>
            <th class="text-start ps-3" style="min-width:180px;">View</th>
            <th title="Can access this view">Can View</th>
            <th title="Members only see records they created">Limit to Own Records</th>
          </tr>
        </thead>
        <tbody>
          {% for row in viewPerm %}
          <tr>
            <td class="text-start ps-3">
              <strong>{{ row.label }}</strong>
              <div class="text-muted" style="font-size:.78rem;"><code>{{ row.view_name }}</code></div>
            </td>
            <td>
              <input type="checkbox" name="vp_{{ row.view_id }}_can_view" value="on"
                class="form-check-input" {% if row.can_view %}checked{% endif %}>
            </td>
            <td>
              <input type="checkbox" name="vp_{{ row.view_id }}_limit_to_own_records" value="on"
                class="form-check-input" {% if row.limit_to_own_records %}checked{% endif %}>
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    <div class="card-footer text-muted" style="font-size:.8rem;">
      <strong>Limit to Own Records</strong>: members only see records they created.
    </div>
  </div>
  {% endif %}

  {% if tablePerm.length > 0 or viewPerm.length > 0 %}
  <div class="mb-4">
    <button type="submit" class="btn btn-primary">Save Permissions</button>
  </div>
  {% endif %}

  {% if tablePerm.length === 0 and viewPerm.length === 0 %}
  <div class="text-muted fst-italic mb-4">
    No tables or views exist yet. Create some first to configure permissions.
  </div>
  {% endif %}

</form>

{# ── Danger zone ──────────────────────────────────────────────────────────────── #}
<div class="card border-danger shadow-sm" style="max-width:680px;">
  <div class="card-header text-danger"><strong>Danger Zone</strong></div>
  <div class="card-body d-flex align-items-center justify-content-between">
    <div>
      <strong>Delete this group</strong>
      <div class="text-muted small">Removes the group and all its permissions. Members in this group will be unaffected but lose group-based access.</div>
    </div>
    <form method="POST" action="/admin/groups/{{ group.id }}/delete"
      onsubmit="return confirm('Delete group {{ group.group_name }}? This cannot be undone.')">
      <button class="btn btn-outline-danger btn-sm">Delete Group</button>
    </form>
  </div>
</div>

{% endif %}
{% endblock %}
