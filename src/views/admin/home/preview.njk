{% extends "admin/layout.njk" %}
{% block content %}
<div class="page-header">
  <h1>Member Home Page <span class="text-muted fw-normal fs-6">/ preview</span></h1>
  <a href="{{ backUrl or '/admin/home' }}" class="btn btn-sm btn-outline-secondary">&larr; Editor</a>
</div>

<div class="card shadow-sm">
  <div class="card-header py-2 d-flex align-items-center gap-2">
    <span class="text-muted small">Preview — rendered as member "Preview User"</span>
  </div>
  <div class="card-body p-4">
    {% if renderedHtml %}
      {{ renderedHtml | safe }}
    {% else %}
      {# Default view list #}
      <div style="max-width:640px; margin:0 auto;">
        <h5 class="mb-3">Your views</h5>
        {% if views.length %}
        <div class="list-group">
          {% for v in views %}
          <div class="list-group-item d-flex align-items-center gap-2">
            <i class="bi bi-table text-muted"></i> {{ v.label }}
          </div>
          {% endfor %}
        </div>
        {% else %}
          <p class="text-muted">No views available.</p>
        {% endif %}
      </div>
    {% endif %}
  </div>
</div>
{% endblock %}
