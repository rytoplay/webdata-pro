<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}{{ title }}{% endblock %}</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  {% if app.member_css_url %}
  <link rel="stylesheet" href="{{ app.member_css_url }}">
  {% endif %}
  <link href="/static/widget-base.css" rel="stylesheet">
  <script src="/static/embed.js"></script>
  {% block head %}{% endblock %}
</head>
<body>

{% if not suppressPortalNav %}
  {% if headerHtml %}
    {{ headerHtml | safe }}
  {% else %}
    <nav class="navbar navbar-dark bg-dark px-3 gap-2">
      <a href="{{ homeUrl or ('/app/' + app.slug + '/') }}" class="navbar-brand fw-semibold text-decoration-none">
        {{ app.name }}
      </a>
      <div class="d-flex align-items-center gap-2 ms-auto">
        {% if sitemapUrl %}
        <a href="{{ sitemapUrl }}" class="btn btn-sm btn-outline-light">
          <i class="bi bi-map me-1"></i>Site Map
        </a>
        {% endif %}
        {% if memberLogoutUrl %}
        <a href="{{ memberLogoutUrl }}" class="btn btn-sm btn-outline-light">Sign out</a>
        {% endif %}
      </div>
    </nav>
  {% endif %}
{% endif %}

{% block content %}{% endblock %}

{% if not suppressPortalNav and footerHtml %}
  {{ footerHtml | safe }}
{% endif %}

</body>
</html>
