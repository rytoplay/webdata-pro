<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { background: #f0f2f5; }
    .auth-card { max-width: 400px; margin: 80px auto; }
  </style>
</head>
<body>
<div class="auth-card">
  <div class="text-center mb-4">
    <div class="fs-4 fw-semibold">{{ app.name }}</div>
    <div class="text-muted small">Choose a new password</div>
  </div>

  <div class="card shadow-sm">
    <div class="card-body p-4">

      {% if flash %}
      <div class="alert alert-{{ flash.type }} py-2 mb-3">{{ flash.message }}</div>
      {% endif %}

      {% if valid %}
      <form method="POST" action="/app/{{ app.slug }}/reset">
        <input type="hidden" name="token" value="{{ token }}">

        <div class="mb-3">
          <label class="form-label">New password</label>
          <input type="password" name="password" class="form-control" required autofocus
            autocomplete="new-password" minlength="8">
          <div class="form-text">At least 8 characters.</div>
        </div>
        <div class="mb-4">
          <label class="form-label">Confirm new password</label>
          <input type="password" name="password_confirm" class="form-control" required
            autocomplete="new-password">
        </div>
        <button type="submit" class="btn btn-primary w-100">Set new password</button>
      </form>
      {% else %}
      <p class="text-muted small">This link is invalid or has expired. <a href="/app/{{ app.slug }}/forgot">Request a new one.</a></p>
      {% endif %}

    </div>
  </div>

  <div class="text-center mt-3 text-muted small">
    <a href="/app/{{ app.slug }}/login">Back to sign in</a>
  </div>
</div>
</body>
</html>
