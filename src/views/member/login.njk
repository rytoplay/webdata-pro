{% extends "member/layout.njk" %}

{% block content %}
<div style="max-width:420px; margin:60px auto; padding:0 1rem 3rem;">

  {% if not headerHtml %}
  <div class="text-center mb-4">
    <div class="fs-4 fw-semibold">{{ app.name }}</div>
    <div class="text-muted small">Sign in to continue</div>
  </div>
  {% endif %}

  <div class="card shadow-sm">
    <div class="card-body p-4">

      {% if flash %}
      <div class="alert alert-{{ flash.type }} py-2 mb-3">{{ flash.message }}</div>
      {% endif %}

      <form method="POST" action="/app/{{ app.slug }}/login">
        <input type="hidden" name="returnTo" value="{{ returnTo }}">

        <div class="mb-3">
          <label class="form-label">Email</label>
          <input type="email" name="email" class="form-control" required autofocus autocomplete="email">
        </div>
        <div class="mb-3">
          <div class="d-flex justify-content-between align-items-baseline">
            <label class="form-label">Password</label>
            <a href="/app/{{ app.slug }}/forgot" class="text-muted small">Forgot password?</a>
          </div>
          <input type="password" name="password" class="form-control" required autocomplete="current-password">
        </div>
        <button type="submit" class="btn btn-primary w-100">Sign in</button>
      </form>

    </div>
  </div>

  {% if allowRegister %}
  <div class="text-center mt-3 text-muted small">
    Don't have an account? <a href="/app/{{ app.slug }}/register">Sign up</a>
  </div>
  {% endif %}

</div>
{% endblock %}
