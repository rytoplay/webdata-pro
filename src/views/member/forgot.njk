<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { background: #f0f2f5; }
    .auth-card { max-width: 400px; margin: 80px auto; }
  </style>
</head>
<body>
<div class="auth-card">
  <div class="text-center mb-4">
    <div class="fs-4 fw-semibold">{{ app.name }}</div>
    <div class="text-muted small">Reset your password</div>
  </div>

  <div class="card shadow-sm">
    <div class="card-body p-4">

      {% if flash %}
      <div class="alert alert-{{ flash.type }} py-2 mb-3">{{ flash.message }}</div>
      {% endif %}

      {% if sent %}
      <div class="text-center py-2">
        <div class="fs-2 mb-2">&#x2709;&#xfe0f;</div>
        <p class="mb-1 fw-semibold">Check your email</p>
        <p class="text-muted small">If an account exists for that address, we've sent a password reset link. Check your spam folder if you don't see it within a few minutes.</p>
      </div>
      {% else %}
      <p class="text-muted small mb-3">Enter your email address and we'll send you a link to reset your password.</p>
      <form method="POST" action="/app/{{ app.slug }}/forgot">
        <div class="mb-3">
          <label class="form-label">Email</label>
          <input type="email" name="email" class="form-control" required autofocus autocomplete="email">
        </div>
        <button type="submit" class="btn btn-primary w-100">Send reset link</button>
      </form>
      {% endif %}

    </div>
  </div>

  <div class="text-center mt-3 text-muted small">
    <a href="/app/{{ app.slug }}/login">Back to sign in</a>
  </div>
</div>
</body>
</html>
