<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
</head>
<body>
<nav class="navbar navbar-light bg-light border-bottom px-3">
  <a href="/app/{{ app.slug }}/" class="navbar-brand mb-0 fw-semibold text-decoration-none">
    <i class="bi bi-chevron-left me-1"></i>{{ app.name }}
  </a>
  <a href="/app/{{ app.slug }}/logout" class="btn btn-sm btn-outline-secondary">Sign out</a>
</nav>

<div class="container py-4">
  <h5 class="mb-3">{{ view.label }}</h5>
  <div id="wdp-view"></div>
</div>

<script src="/static/embed.js"></script>
<script>
  WDP.mount('#wdp-view', {
    app:     '{{ app.slug }}',
    view:    '{{ view.view_name }}',
    baseUrl: '',
    {% if singleRecord %}
    initialMode: '{{ "edit" if existingRecordId else "create" }}',
    {% if existingRecordId %}initialId: '{{ existingRecordId }}',{% endif %}
    {% endif %}
  });
</script>
</body>
</html>
