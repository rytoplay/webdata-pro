{% extends "member/layout.njk" %}

{% block head %}
<style>
  .view-body { max-width: 1100px; margin: 1.5rem auto; padding: 0 1.5rem 3rem; }
  .view-title { font-size: 1.3rem; font-weight: 800; margin-bottom: 1rem;
                font-family: Arial, sans-serif; color: var(--green-dark, #1e40af); }
</style>
{% endblock %}

{% block content %}
<div class="view-body">
  <div class="view-title">{{ view.label }}</div>
  <div id="wdp-view"></div>
</div>

<script>
  WDP.mount('#wdp-view', {
    app:     '{{ app.slug }}',
    view:    '{{ view.view_name }}',
    baseUrl: '',
    {% if singleRecord %}
    initialMode: '{{ "edit" if existingRecordId else "create" }}',
    {% if existingRecordId %}initialId: '{{ existingRecordId }}',{% endif %}
    {% endif %}
  });
</script>
{% endblock %}
