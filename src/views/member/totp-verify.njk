<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { background: #f0f2f5; }
    .auth-card { max-width: 400px; margin: 80px auto; }
    .totp-input { font-size: 1.6rem; letter-spacing: 0.4em; text-align: center; font-weight: 700; }
  </style>
</head>
<body>
<div class="auth-card">
  <div class="text-center mb-4">
    <div class="fs-4 fw-semibold">{{ app.name }}</div>
    <div class="text-muted small">Two-factor authentication</div>
  </div>

  <div class="card shadow-sm">
    <div class="card-body p-4">

      {% if flash %}
      <div class="alert alert-{{ flash.type }} py-2 mb-3">{{ flash.message }}</div>
      {% endif %}

      <p class="text-muted small mb-3">Open your authenticator app and enter the 6-digit code for <strong>{{ app.name }}</strong>.</p>

      <form method="POST" action="/app/{{ app.slug }}/totp-verify">
        <div class="mb-4">
          <label class="form-label">Authentication code</label>
          <input type="text" name="code" class="form-control totp-input"
            inputmode="numeric" pattern="[0-9]{6}" maxlength="6"
            required autofocus autocomplete="one-time-code"
            placeholder="000000">
        </div>
        <button type="submit" class="btn btn-primary w-100">Verify</button>
      </form>

    </div>
  </div>

  <div class="text-center mt-3 text-muted small">
    <a href="/app/{{ app.slug }}/login">Back to sign in</a>
  </div>
</div>
</body>
</html>
