# ── Required ──────────────────────────────────────────────────────────────────

# Admin login credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Session encryption key — use a long random string in production
SESSION_SECRET=change-me-to-a-random-secret

# ── Railway / Persistent storage ─────────────────────────────────────────────
# Set this to the mount path of your Railway Volume (e.g. /data).
# All SQLite databases (control DB + per-app DBs) will be stored here.
# Without a Volume, data is lost on every redeploy.
DATA_DIR=/data

# ── Optional overrides ────────────────────────────────────────────────────────
# PORT is set automatically by Railway — only override locally if needed
# PORT=3000

# Override the control DB path explicitly (defaults to $DATA_DIR/webdata-pro.sqlite)
# SQLITE_PATH=/data/webdata-pro.sqlite

# Node environment (Railway sets this to "production" automatically)
# NODE_ENV=production
